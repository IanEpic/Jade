//- viewPage-content.pug
//- Standalone user page (no sidebar). Admin can switch a page to the sidebar layout
//- via UserPage.withsidebar (then /viewPage redirects to /home?action=userpage).

style.
    .up-page { max-width: 760px; margin: 0 auto; }
    .up-card { border: 1px solid var(--border-dashed); border-radius: 6px; background: #181818; padding: 20px 24px; }
    .up-card, .up-card p, .up-card li, .up-card td { color: #e6e6e6; line-height: 1.6; }
    .up-card a { color: #c9b27a; }
    .up-card a:hover { color: var(--color-accent); }
    .up-card h1, .up-card h2, .up-card h3, .up-card h4 { color: var(--color-accent-strong); }
    .up-card img { max-width: 100%; height: auto; }
    .up-actions { text-align: center; margin-top: 18px; }

.up-page
    .up-card
        if page
            != page.html
        else
            p Page not found.
    .up-actions
        a.btn-secondary(href='/home') Home
