//- home/catcost.pug
//- Equiv of $catcosttable in home.cgi.

- let hasCosts = content.cats.some(c => (parseFloat(c.costex)||0) + (parseFloat(c.gst)||0) > 0)

center: h3= 'Categories' + (hasCosts ? ' and Entry Costs' : '')

if content.program && content.program.costexplanationtext
    p!= content.program.costexplanationtext

table(width='640')
    each cat, i in content.cats
        if i > 0
            tr: td(colspan='2'): hr
        tr: td(colspan='2'): b= cat.name
        tr: td(style='padding-left:10px;')= cat.description
