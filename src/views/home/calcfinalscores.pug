-
    var slug        = program.slug
    var baseUrl     = '/' + slug + '/home?action=calcfinalscores'
    var ignoreReady = content.ignoreReady
    var topN        = content.topN
    var ignoreQs    = (ignoreReady ? '&ignoreScoreReady=1' : '') + '&topN=' + topN

style.
    .cfs-wrap { max-width: 900px; margin: 0 auto; }
    .cfs-wrap h2 { text-align: center; color: #c48f06; margin-bottom: 20px; }
    .cfs-options { display: flex; align-items: center; gap: 24px; margin-bottom: 16px; flex-wrap: wrap; }
    .cfs-options label { display: flex; align-items: center; gap: 6px; font-size: 13px; color: #bbb; }
    .cfs-options input[type=number] { width: 60px; background: #111; color: #fff; border: 1px solid #555; border-radius: 4px; padding: 4px 8px; font-size: 13px; }
    .cfs-options input[type=number]:focus { border-color: #c48f06; outline: none; }
    .finalist-badge { display: inline-block; font-size: 11px; padding: 1px 6px; border-radius: 2px; font-weight: 600; background: #1a3a4a; color: #64b5f6; }
    .form-actions { margin-top: 16px; display: flex; gap: 8px; align-items: center; }

.cfs-wrap
    h2 Calculate Final Scores

    if content.wrote
        div(style='background:#1a4a1a; border-left:4px solid #4c4; color:#cfc; padding:10px 14px; font-size:13px; margin-bottom:14px;')
            | Final scores written to database (#{content.rowCount} entries). Top #{topN} per category flagged as finalists.

    p This page calculates final scores for all score-ready categories and marks the top #{topN} entries per category as finalists.

    .cfs-options
        label
            input(type='checkbox' data-action='toggle-ignore-ready' data-base-url=baseUrl data-topn=topN checked=ignoreReady)
            |  Include non-score-ready categories (validation only)
        label
            | Top
            input(type='number' id='topNInput' min='1' max='99' value=topN)
            | finalists per category

    if !content.preview.length
        p(style='color:#aaa;') No scored entries found for this program#{ ignoreReady ? '' : ' with Score Ready categories' }.

    else
        p(style='color:#aaa; font-size:12px;') #{content.preview.length} entries across #{content.categoryCount} categories.

        table.data-table(style='width:100%;')
            thead
                tr
                    th(style='width:40px;') Rank
                    th Category
                    th Entrant
                    th(style='width:80px;') Score
                    th(style='width:80px; text-align:center;') Finalist
            tbody
                each r in content.preview
                    tr
                        td= r.rank
                        td= r.categoryname
                        td= r.entrantname
                        td= r.finalscore.toFixed(2)
                        td(style='text-align:center;')
                            if r.finalist
                                span.finalist-badge Finalist

        .form-actions
            form(method='POST' action=baseUrl+'&confirm=1'+ignoreQs)
                button.btn(type='submit') Write Scores &amp; Set Finalists
            a.btn-secondary(href='/' + slug + '/home?action=program') Cancel

script.
    function cfsNavigate() {
        var checked = document.querySelector('[data-action="toggle-ignore-ready"]').checked;
        var n = document.getElementById('topNInput').value || 5;
        var base = (window.JADE_BASE || '') + '/home?action=calcfinalscores';
        location.href = base + (checked ? '&ignoreScoreReady=1' : '') + '&topN=' + n;
    }
    document.addEventListener('change', function(e) {
        if (e.target.closest('[data-action="toggle-ignore-ready"]') || e.target.id === 'topNInput') {
            cfsNavigate();
        }
    });
