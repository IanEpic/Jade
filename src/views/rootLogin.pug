extends layout

block content
    div(style='max-width:420px; margin:80px auto; font-family:sans-serif;')
        h2(style='text-align:center;') JADE Awards — Login

        div#login-config(style='display:none'
            data-check-url=checkUrl
            data-login-url=loginUrl
            data-reset-url=resetUrl)

        //- ── Step 1: Email ───────────────────────────────────────────────────
        div#step-email
            form#form-email(autocomplete='on')
                table
                    tr: td(colspan='2'): input#login-email(type='email' name='email' size='35' maxlength='300' autocomplete='email' placeholder='Please enter your email address' value=loginEmail||'')
                    tr: td(colspan='2' style='text-align:center; padding-top:8px;'): button#btn-continue.btn(type='submit') Continue →
                    tr: td(colspan='2')
                        div#email-error(style='color:#c0392b; margin-top:6px; display:none;')

        //- ── Step 2: Password ────────────────────────────────────────────────
        div#step-password(style='display:none;')
            form#form-password(method='POST' action=loginUrl autocomplete='on')
                input#pw-email(type='hidden' name='email' value=loginEmail||'')
                table
                    tr: td(colspan='2')
                        span#password-greeting
                    tr: td(colspan='2', style='padding-top:12px;')
                    tr: td(colspan='2'): input#login-password(type='password' name='password' size='35' maxlength='50' autocomplete='current-password' placeholder='Password')
                    tr: td(colspan='2' style='text-align:center; padding-top:8px;'): button.btn(type='submit') Log In
                    tr: td(colspan='2')
                        if errors && errors.length
                            each e in errors
                                p(style='color:#c0392b; margin:4px 0;')= e
                div(style='text-align:center; margin-top:10px; font-size:0.85em; color:#aaa;')
                    a#reset-link(href=resetUrl) Forgot your password?
                    span(style='margin:0 8px;') ·
                    a(href='#' id='btn-back-from-pw') Use a different email

        //- ── Step: Not found ─────────────────────────────────────────────────
        div#step-notfound(style='display:none;')
            p No account was found for that email address. Please check the address or contact the program administrator.
            a(href='#' id='btn-back-from-notfound') ← Try a different email

    script(src='/js/root-login.js')
