//- home/entrants.pug
//- Equiv of $entranttable in home.cgi.

style.
    .entrants-wrap { max-width: 900px; margin: 0 auto; font-size: 14px; }
    .entrants-wrap h2 { text-align: center; color: #c48f06; margin-bottom: 20px; }
    .entrants-wrap fieldset { border: 1px solid #555; border-radius: 4px; margin-bottom: 14px; padding: 14px 18px; }
    .entrants-wrap legend { font-size: 12px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; color: #c48f06; padding: 0 8px; }
    .entrant-form-wrap { display: none; background: #111; border: 1px solid #555; border-radius: 4px; padding: 16px 18px; margin-bottom: 16px; }
    .entrant-form-wrap h4 { color: #c48f06; margin: 0 0 14px; font-size: 15px; }
    .entrant-form table { border-collapse: collapse; width: 100%; }
    .entrant-form td { padding: 5px 8px; vertical-align: middle; }
    .entrant-form td:first-child { text-align: right; width: 140px; padding-right: 10px; white-space: nowrap; }
    .entrant-form input[type=text], .entrant-form select { background: #1a1a1a; color: #eee; border: 1px solid #555; padding: 5px 8px; border-radius: 3px; font-size: 13px; width: 100%; box-sizing: border-box; }
    .entrant-form td:first-child + td { width: 260px; }
    .entrant-form .form-actions { margin-top: 14px; display: flex; gap: 10px; align-items: center; padding-top: 12px; border-top: 1px solid #333; }
    .entrant-form .addr-fields { display: none; margin-top: 6px; }
    .entrant-form .addr-fields td:first-child { width: 80px; }
    .entrants-toolbar { display: flex; justify-content: flex-end; margin-bottom: 10px; }
    .entrants-table { width: 100%; border-collapse: collapse; }
    .entrants-table th { font-size: 12px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; border-bottom: 1px solid #555; padding: 6px 10px; text-align: left; color: #c48f06; }
    .entrants-table td { padding: 7px 10px; border-bottom: 1px solid #2a2a2a; vertical-align: middle; font-size: 14px; }
    .entrants-table tr:hover td { background: rgba(255,255,255,0.04); }
    .entrants-table .actions { white-space: nowrap; }
    .entrants-table .actions a { margin-right: 6px; font-size: 16px; color: #aaa; text-decoration: none; }
    .entrants-table .actions a:hover { color: #c48f06; }

- var canEdit = content.catsOpenForEntries.length || content.overrideOpen.length
- var fd = content.formData || {}

.entrants-wrap
    h2= content.entrantsLabel || 'My Entrants'

    if content.error
        p(style='background:#7a2a00; color:#fff; padding:8px 12px; border-left:4px solid #c44; margin-bottom:12px')= content.error

    if canEdit
        //- ── Inline new/edit form ─────────────────────────────────────────────
        .entrant-form-wrap#entrant-form-wrap(style=content.error ? 'display:block' : 'display:none')
            h4#entrant-form-title= (fd.entrantid ? (content.editLabel || 'Edit Entrant') : (content.createLabel || 'New Entrant'))
            form.entrant-form(method='POST' action='/formEntrant' id='entrant-form')
                input#entrant-id-field(type='hidden' name='entrantid' value=fd.entrantid || '')
                table
                    tr
                        td= content.nameLabel || 'Entrant Name'
                        td: input(type='text' name='name' id='ef-name' maxlength='300' value=fd.name || '')
                    tr
                        td= content.typeLabel || 'Entrant Type'
                        td
                            select(name='type' id='ef-type')
                                each opt in ['Individual', 'Business', 'Company']
                                    option(value=opt selected=(fd.type === opt))= opt
                    tr
                        td Legal Entity Name
                        td: input(type='text' name='legalentity' id='ef-legalentity' maxlength='300' value=fd.legalentity || '')
                    tr
                        td= content.abnLabel || 'ABN'
                        td: input(type='text' name='abn' id='ef-abn' maxlength='20' value=fd.abn || '')

                    if content.addresses && content.addresses.length
                        tr
                            td Street Address
                            td
                                select(name='streetaddressid' id='ef-street-sel')
                                    option(value='a' selected=(!fd.streetaddressid || fd.streetaddressid === 'a')) — Please Select —
                                    option(value='b' selected=(fd.streetaddressid === 'b')) + New Address Below
                                    each addr in content.addresses
                                        option(value=addr.addressid selected=(String(addr.addressid) === String(fd.streetaddressid)))= addr.address + ', ' + addr.city + ', ' + addr.state
                        tr
                            td
                            td
                                table.addr-fields#ef-street-fields
                                    tr
                                        td Address
                                        td: input(type='text' name='streetaddress' maxlength='100')
                                    tr
                                        td City
                                        td: input(type='text' name='streetcity' maxlength='50')
                                    tr
                                        td State
                                        td: input(type='text' name='streetstate' maxlength='20')
                                    tr
                                        td Postcode
                                        td: input(type='text' name='streetcode' maxlength='10')
                                    tr
                                        td Country
                                        td: input(type='text' name='streetcountry' value='Australia' maxlength='50')
                        tr
                            td Postal Address
                            td
                                select(name='postaladdressid' id='ef-postal-sel')
                                    option(value='a' selected=(!fd.postaladdressid || fd.postaladdressid === 'a')) — Please Select —
                                    option(value='b' selected=(fd.postaladdressid === 'b')) + New Address Below
                                    option(value='c' selected=(fd.postaladdressid === 'c')) Same as Street
                                    each addr in content.addresses
                                        option(value=addr.addressid selected=(String(addr.addressid) === String(fd.postaladdressid)))= addr.address + ', ' + addr.city + ', ' + addr.state
                        tr
                            td
                            td
                                table.addr-fields#ef-postal-fields
                                    tr
                                        td Address
                                        td: input(type='text' name='postaladdress' maxlength='100')
                                    tr
                                        td City
                                        td: input(type='text' name='postalcity' maxlength='50')
                                    tr
                                        td State
                                        td: input(type='text' name='postalstate' maxlength='20')
                                    tr
                                        td Postcode
                                        td: input(type='text' name='postalcode' maxlength='10')
                                    tr
                                        td Country
                                        td: input(type='text' name='postalcountry' value='Australia' maxlength='50')

                    tr
                        td Telephone
                        td: input(type='text' name='telephone' id='ef-telephone' maxlength='300' value=fd.telephone || '')
                    tr
                        td Mobile
                        td: input(type='text' name='mobile' id='ef-mobile' maxlength='50' value=fd.mobile || '')
                    tr
                        td Email
                        td: input(type='text' name='email' id='ef-email' maxlength='100' value=fd.email || '')

                .form-actions
                    button#entrant-submit-btn(type='submit')= (fd.entrantid ? 'Save Entrant' : (content.createLabel || 'Create Entrant'))
                    a.btn-secondary(href='#' id='entrant-cancel') Cancel

        //- ── Toolbar ─────────────────────────────────────────────────────────
        .entrants-toolbar
            a(href='#' id='btn-new-entrant') + #{content.newEntrantLabel || 'New Entrant'}

    //- ── List table ──────────────────────────────────────────────────────────
    fieldset
        legend= content.entrantNoLabel || 'Entrants'
        table.entrants-table
            thead
                tr
                    th(style='width:60px') #
                    th(style='min-width:200px') Name
                    th(style='min-width:120px') Type
                    th(style='width:60px')
            tbody
                each entrant in content.entrants
                    tr(
                        data-id=entrant.entrantid
                        data-name=entrant.name
                        data-type=entrant.type
                        data-legalentity=(entrant.legalentity || '')
                        data-abn=(entrant.abn || '')
                        data-street=String(entrant.streetaddressid || '')
                        data-postal=String(entrant.postaladdressid || '')
                        data-telephone=(entrant.telephone || '')
                        data-mobile=(entrant.mobile || '')
                        data-email=(entrant.email || '')
                    )
                        td= entrant.entrantid
                        td= entrant.name
                        td= entrant.type
                        td.actions
                            if canEdit
                                a(href='#' title='Edit' data-action='edit-entrant') ✏️
                                a(href='/formEntrant?entrantid=' + entrant.entrantid + '&action=delete' title='Delete' data-confirm='Delete this entrant?' style='color:#c44') ✕

script(src='/js/home-entrants.js?v=' + buildHash)
