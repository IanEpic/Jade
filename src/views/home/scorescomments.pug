//- home/scorescomments.pug

style.
    .sc-wrap { max-width: 700px; margin: 0 auto; }
    .sc-wrap h2 { text-align: center; color: var(--color-accent-strong); margin-bottom: 20px; }
    .sc-card { border: 1px solid var(--border-dashed); border-radius: 4px; margin-bottom: 20px; overflow: hidden; }
    .sc-card-header { background: var(--surface-1); padding: 10px 16px; border-bottom: 1px solid var(--border-subtle); }
    .sc-card-header .cat { font-size: 13px; font-weight: 600; color: var(--color-accent-strong); }
    .sc-card-header .meta { font-size: 12px; color: var(--text-dim); margin-top: 2px; }
    .sc-body { padding: 14px 16px; }
    .sc-score-row { display: flex; align-items: baseline; gap: 16px; margin-bottom: 14px; flex-wrap: wrap; }
    .sc-final-score { font-size: 28px; font-weight: 700; color: var(--color-text); }
    .sc-final-label { font-size: 12px; color: var(--text-dim); }
    .sc-explain { font-size: 12px; color: var(--color-accent-strong); }
    .sc-criteria { margin-bottom: 14px; }
    .sc-criteria table { width: 100%; border-collapse: collapse; }
    .sc-criteria th { font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; color: var(--text-dim); padding: 4px 8px; border-bottom: 1px solid var(--border-faint); text-align: left; }
    .sc-criteria th.r { text-align: right; }
    .sc-criteria td { font-size: 13px; padding: 5px 8px; border-bottom: 1px solid var(--surface-1); color: var(--color-muted); }
    .sc-criteria td.r { text-align: right; color: var(--color-text); font-weight: 600; }
    .sc-criteria td.w { text-align: right; color: var(--border-mid); font-size: 12px; }
    .sc-criteria tr:last-child td { border-bottom: none; }
    .sc-section { margin-bottom: 14px; }
    .sc-section-title { font-size: 12px; font-weight: 600; color: var(--color-accent-strong); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 6px; }
    .sc-comment { font-size: 13px; color: var(--color-muted); padding: 6px 0; border-bottom: 1px solid var(--surface-1); }
    .sc-comment:last-child { border-bottom: none; }
    .sc-divider { border: none; border-top: 1px solid var(--border-subtle); margin: 0; }
    .sc-home { text-align: center; margin-top: 20px; }

.sc-wrap
    h2 Scores &amp; Comments

    each entry in content.entries
        - var excel   = entry.comments.filter(function(c){ return c.type === 'excel' })
        - var improve = entry.comments.filter(function(c){ return c.type === 'improve' })
        - var other   = entry.comments.filter(function(c){ return c.type === 'other' })
        - var score   = entry.finalScore ? parseFloat(entry.finalScore.finalscore).toFixed(2) : null
        - var hasCriteria = entry.criteriaScores && entry.criteriaScores.length > 0

        .sc-card
            .sc-card-header
                div.cat= entry.categoryname
                div.meta
                    | Entry ##{entry.entryid}
                    if entry.userref
                        |  &nbsp;·&nbsp; Ref: #{entry.userref}

            .sc-body
                if score
                    .sc-score-row
                        div
                            div.sc-final-score= score
                            div.sc-final-label Final Score
                        a.sc-explain(href='/home?action=explainscores') How is my score calculated?

                if hasCriteria
                    .sc-criteria
                        table
                            thead
                                tr
                                    th Criteria
                                    th.r(style='width:60px;') Score
                                    th.w(style='width:50px;') Weight
                            tbody
                                each c in entry.criteriaScores
                                    tr
                                        td= (c.criterianame || '').replace(/<[^>]+>/g, '')
                                        td.r= (c.score !== null && c.score !== undefined) ? parseFloat(c.score).toFixed(2) : ''
                                        td.w= c.weight ? c.weight + '%' : ''

                if excel.length
                    .sc-section
                        div.sc-section-title Areas of Excellence
                        each c in excel
                            div.sc-comment= c.comment

                if improve.length
                    .sc-section
                        div.sc-section-title Areas for Improvement
                        each c in improve
                            div.sc-comment= c.comment

                if other.length
                    .sc-section
                        div.sc-section-title Other Comments
                        each c in other
                            div.sc-comment= c.comment

                if !excel.length && !improve.length && !other.length && !score
                    p(style='color:var(--border-mid); font-size:13px;') No scores or comments are available for this entry yet.

    .sc-home
        a.btn-secondary(href='/' + content.program.slug + '/home') Home
