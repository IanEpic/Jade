extends layout

block content
    div(style='max-width:420px; margin:80px auto; font-family:sans-serif;')
        h2(style='text-align:center;') JADE Awards — Password Reset

        if errors && errors.length
            each e in errors
                p(style='color:#c0392b;')= e

        if state === 'sent'
            p A temporary password has been sent to #[b= email]. Please check your inbox (and spam folder), then enter it below.
            br
            form(method='POST' action=loginUrl)
                input(type='hidden' name='email' value=email)
                table
                    tr
                        td Temporary password
                        td: input(type='password' name='password' size='30' maxlength='50' autocomplete='current-password' autofocus)
                    tr: td(colspan='2'): hr
                    tr: td(colspan='2' align='center')
                        button(type='submit') Log In
            p: a(href=loginUrl) Back to login

        else
            p Enter your email address and we will send you a temporary password.
            br
            form(method='POST' action=resetUrl)
                table
                    tr
                        td Email address
                        td: input(type='email' name='email' size='35' maxlength='300' autocomplete='email' required value=email||'')
                    tr: td(colspan='2'): hr
                    tr: td(colspan='2' align='center')
                        button(type='submit') Send Temporary Password
            p: a(href=loginUrl) Back to login
