//- passwordReset-content.pug
//- state: 'blank' | 'sent'

- let loginUrl = '/' + program.slug + '/login'
- let resetUrl = '/' + program.slug + '/password-reset'

if errors && errors.length
    each e in errors
        p(style='color:#c0392b;')= e

if state === 'sent'
    p A temporary password has been sent to #[b= email]. Please check your inbox (and spam folder).
    p Once you have your temporary password, log in and change it straight away via #[b My Profile].
    p: a(href=loginUrl) ← Back to login

else
    p Enter your email address below and we will send you a temporary password.
    br
    form(method='POST' action=resetUrl)
        table
            tr
                td Email address
                td: input(type='email' name='email' size='40' maxlength='300' autocomplete='email' required)
            tr: td(colspan='2'): hr
            tr: td(colspan='2' align='center')
                button(type='submit') Send Temporary Password
    p: a(href=loginUrl) ← Back to login
