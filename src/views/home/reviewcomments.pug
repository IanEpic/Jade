//- home/reviewcomments.pug
//- Admin review queue, grouped by judge. Per judge: tick entries and send them
//- all back for rework in one email. Per comment: clear the flag (optionally add
//- the comment to the guidelines as a good example).

style.
    .rc-wrap { max-width: 800px; margin: 0 auto; }
    .rc-wrap h3 { color: var(--color-accent-strong); text-align: center; margin-bottom: 16px; }
    .rc-judge { font-weight: bold; background: var(--border-subtle); padding: 6px 10px; margin: 18px 0 8px; border-radius: 3px; color: var(--color-text); }
    .rc-entry { border: 1px solid var(--border-faint); border-radius: 4px; padding: 10px 12px; margin-bottom: 10px; }
    .rc-entry-head { display: flex; justify-content: space-between; align-items: center; margin-bottom: 6px; }
    .rc-pick { display: flex; align-items: center; gap: 8px; color: var(--color-muted); cursor: pointer; }
    .rc-pick input { accent-color: var(--color-accent-strong); width: 15px; height: 15px; }
    .rc-pick .id { color: var(--text-dim); }
    .rc-pick .cat { color: var(--text-dim); font-size: 12px; }
    .rc-badge { background: #8b3a00; color: #ffd; font-size: 11px; padding: 2px 8px; border-radius: 3px; }
    .rc-comment { border-top: 1px solid var(--surface-2); padding-top: 8px; margin-top: 8px; }
    .rc-ctype { font-size: 11px; text-transform: uppercase; letter-spacing: 0.05em; color: var(--text-dim); }
    .rc-ctext { white-space: pre-wrap; color: var(--text-strong); font-size: 14px; margin: 2px 0 4px; }
    .rc-reason { background: #2a1a00; border-left: 3px solid var(--color-accent-strong); color: #e0b060; font-size: 13px; padding: 5px 9px; margin: 4px 0; border-radius: 2px; }
    .rc-reason b { color: var(--color-accent-strong); margin-right: 5px; }
    .rc-clearrow { display: flex; align-items: center; gap: 12px; font-size: 12px; color: var(--text-arrow); margin-top: 4px; }
    .rc-clear { background: none; border: 1px solid #4a7a4a; color: #8fce8f; border-radius: 3px; font-size: 12px; padding: 2px 10px; cursor: pointer; }
    .rc-clear:hover { background: #1a3a1a; }
    .rc-example { display: flex; align-items: center; gap: 5px; cursor: pointer; }
    .rc-example input { accent-color: var(--color-accent-strong); }
    .rc-sendback { background:#7a2a2a; color:#fff; border:0; border-radius:4px; padding:6px 14px; font-size:13px; cursor:pointer; margin: 4px 0 8px; }
    .rc-sendback:hover { background:#a33; }
    .rc-none { color: var(--border-mid); font-style: italic; }
    .rc-ok { background:#1a4a1a; color:#fff; padding:8px 12px; border-left:4px solid #4caf50; margin-bottom:14px; }

.rc-wrap
    h3 Review Judge Comments

    if content.sent
        p.rc-ok Selected entries sent back for rework — the judge has been emailed.
    if content.cleared
        p.rc-ok Flag cleared.

    if !content.judges.length
        p.rc-none No comments are currently flagged for review.

    each judge in content.judges
        .rc-judge= judge.firstname + ' ' + judge.lastname
        form(method='POST' action='/judgeRework')
            input(type='hidden' name='userid' value=judge.userid)
            each entry in judge.entries
                .rc-entry
                    .rc-entry-head
                        if entry.commentreview
                            span.rc-pick
                                span.id= entry.entryid
                                = ' ' + entry.entrantname
                                span.cat=  ' — ' + entry.categoryname
                            span.rc-badge Awaiting rework
                        else
                            label.rc-pick
                                input(type='checkbox' name='entryids' value=entry.entryid)
                                span.id= entry.entryid
                                = ' ' + entry.entrantname
                                span.cat=  ' — ' + entry.categoryname
                    each c in entry.comments
                        .rc-comment
                            .rc-ctype= c.type === 'excel' ? 'Excelled' : (c.type === 'improve' ? 'Could improve' : 'Other')
                            .rc-ctext= c.comment
                            if c.reviewreason
                                .rc-reason
                                    b Flagged:
                                    = c.reviewreason
                            .rc-clearrow
                                button.rc-clear(type='button' data-commentid=c.commentid) Looks OK — clear flag
                                label.rc-example
                                    input(type='checkbox' class='rc-addex')
                                    | add as a good example to the guidelines
            button.rc-sendback(type='submit') Send selected back for rework

script.
    document.querySelectorAll('.rc-clear').forEach(function (btn) {
        btn.addEventListener('click', function () {
            var row = btn.closest('.rc-clearrow');
            var ex  = row.querySelector('.rc-addex');
            btn.disabled = true;
            var body = new URLSearchParams();
            body.set('commentid', btn.dataset.commentid);
            body.set('addexample', ex && ex.checked ? '1' : '0');
            fetch((window.JADE_BASE || '') + '/judgeRework/clear', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded', 'X-Requested-With': 'XMLHttpRequest' },
                body: body.toString(),
            }).then(function (r) { return r.json(); }).then(function (d) {
                if (d.ok) window.location.reload();
                else { btn.disabled = false; alert('Could not clear the flag.'); }
            }).catch(function () { btn.disabled = false; alert('Could not clear the flag.'); });
        });
    });
