{
  "name": "jade",
  "version": "1.0.0",
  "description": "JADE Awards Platform",
  "type": "module",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/app.js",
    "dev": "concurrently \"nodemon src/app.js\" \"stylus --watch src/styles/main.styl --out public/css\"",
    "build:css": "stylus src/styles/main.styl --out public/css",
    "build": "npm run build:css"
  },
  "dependencies": {
    "apache-crypt": "^1.2.6",
    "bcryptjs": "^3.0.3",
    "connect-mssql-v2": "^6.0.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-session": "^1.18.0",
    "fluent-ffmpeg": "^2.1.3",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "mssql": "^12.5.5",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.10",
    "pug": "^3.0.2",
    "sequelize": "^6.37.3",
    "sharp": "^0.34.5",
    "tedious": "^19.2.1"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "nodemon": "^3.1.0",
    "stylus": "^0.64.0"
  },
  "overrides": {
    "uuid": "^11.1.1"
  }
}
