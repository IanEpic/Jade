//- home/entrylist.pug

style.
    .el-wrap { max-width: 900px; margin: 0 auto; }
    .el-wrap h3 { color: #c48f06; font-size: 18px; text-align: center; margin-bottom: 16px; }
    .el-table { width: 100%; border-collapse: collapse; }
    .el-table th { font-size: 12px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; border-bottom: 1px solid #555; padding: 6px 10px; text-align: left; color: #c48f06; }
    .el-table td { padding: 7px 10px; border-bottom: 1px solid #2a2a2a; vertical-align: middle; font-size: 14px; }
    .el-table tr:hover td { background: rgba(255,255,255,0.04); }
    .el-table tr.hidden { display: none; }
    .badge { display: inline-block; font-size: 11px; padding: 1px 6px; border-radius: 2px; font-weight: 600; }
    .badge-entered  { background: #1a4a1a; color: #4caf50; }
    .badge-invoiced { background: #1a2a4a; color: #64b5f6; }
    .badge-unpaid   { background: #3a2a00; color: #c48f06; }
    .el-toolbar { display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px; }
    .el-toolbar a { font-size: 13px; white-space: nowrap; margin-left: 12px; }
    #entry-search { flex: 1; max-width: 320px; padding: 6px 10px; background: #111; color: #fff; border: 1px solid #555; font-size: 14px; }
    #entry-search:focus { border-color: #c48f06; outline: none; }

.el-wrap
    h3 All Entries

- let entered  = content.entries.filter(e => e.entryaccepted)
- let invoiced = content.entries.filter(e => !e.entryaccepted && e.invoiceid && !e.invoicedeleted)
- let unpaid   = content.entries.filter(e => !e.entryaccepted && (!e.invoiceid || e.invoicedeleted))
- let sorted   = [...entered, ...invoiced, ...unpaid]

form(onsubmit='return false')
    .el-toolbar
        input#entry-search(type='text' placeholder='Search entries…' oninput='filterEntries(this.value)')

    table.el-table
        thead
            tr
                th #
                th Entrant
                th(style='min-width:200px') Category
                th Status
                th
        tbody
            each entry in sorted
                - let pmt = entry.entryaccepted ? 'Entered' : (entry.invoiceid && !entry.invoicedeleted ? 'Invoiced' : 'Unpaid')
                - let badgeClass = entry.entryaccepted ? 'badge-entered' : (entry.invoiceid && !entry.invoicedeleted ? 'badge-invoiced' : 'badge-unpaid')
                tr
                    td(style='color:#888; width:50px')= entry.entryid
                    td= entry.finalisttext || entry.entrantname
                    td= entry.categoryname
                    td: span.badge(class=badgeClass)= pmt
                    td(style='white-space:nowrap')
                        a(href='/viewEntry?entryid=' + entry.entryid) View

script.
    function filterEntries(q) {
        q = q.toLowerCase();
        document.querySelectorAll('.el-table tbody tr').forEach(function(row) {
            row.classList.toggle('hidden', q.length > 0 && row.textContent.toLowerCase().indexOf(q) === -1);
        });
    }
    document.getElementById('entry-search').focus();
