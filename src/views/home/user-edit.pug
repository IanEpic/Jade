//- home/user-edit.pug

style.
    .user-form { max-width: 720px; margin: 0 auto; }
    .user-form fieldset { border: 1px solid #666; border-radius: 4px; margin-bottom: 16px; padding: 12px 18px; }
    .user-form legend { font-weight: bold; padding: 0 6px; color: #c48f06; }
    .user-form table { border-collapse: collapse; width: 100%; }
    .user-form td { padding: 4px 8px; vertical-align: middle; }
    .user-form td:first-child { white-space: nowrap; text-align: right; padding-right: 12px; width: 1%; }
    .user-form input[type=text], .user-form input[type=email], .user-form input[type=password] { background: #1a1a1a; color: #eee; border: 1px solid #555; padding: 5px 8px; border-radius: 3px; font-size: 13px; width: 100%; box-sizing: border-box; }
    .user-form select { background: #1a1a1a; color: #eee; border: 1px solid #555; padding: 5px 8px; border-radius: 3px; font-size: 13px; }
    .user-form .cb-row td:first-child { text-align: left; width: 1%; padding-right: 6px; white-space: nowrap; }
    .user-form .cb-row label { font-size: 13px; }
    .user-form .alert-error { background: #7a2a00; color: #fff; padding: 8px 12px; margin-bottom: 12px; border-left: 4px solid #c44; }
    .user-form .note { color: #888; font-size: 12px; }
    .user-form .cat-grid { columns: 3; column-gap: 20px; margin-top: 6px; }
    .user-form .cat-grid label { font-size: 13px; display: flex; align-items: baseline; gap: 5px; break-inside: avoid; padding: 3px 0; }
    .user-form .form-actions { text-align: center; margin-top: 10px; }
    .user-form .form-actions a, .user-form .form-actions button { margin: 0 6px; }
    .user-form .action-links { font-size: 13px; color: #aaa; margin-bottom: 12px; text-align: center; }
    .user-form .action-links a { margin: 0 8px; }

if content.saved
    p(style='color:#4caf50; text-align:center; margin-bottom:12px') Saved.

form.user-form(method='POST' action='/formUser')
    input(type='hidden' name='edituserid' value=content.targetUser.userid)

    h2(style='text-align:center; color:#c48f06') Edit User — #{content.targetUser.firstname} #{content.targetUser.lastname}

    if content.error
        p.alert-error= content.error

    //- Admin quick-actions
    if content.isAdmin && content.operator.userid !== content.targetUser.userid
        .action-links
            a(href='/formUser?action=delete&edituserid=' + content.targetUser.userid onclick='return confirm("Delete this user?")' style='color:#c44') Delete
            if content.targetUser.enabled
                a(href='/formUser?action=disable&edituserid=' + content.targetUser.userid) Disable
            else
                a(href='/formUser?action=enable&edituserid=' + content.targetUser.userid) Enable
            if !content.targetActivated
                a(href='/formUser?action=activate&edituserid=' + content.targetUser.userid) Activate Account
            if content.targetUser.judge
                a(href='/formUser?action=demote&edituserid=' + content.targetUser.userid onclick='return confirm("Remove all judging data?")') Demote from Judge

    //- ── Login details ────────────────────────────────────────────────────────
    fieldset
        legend Login Details
        table
            tr
                td Email Address
                td: input(type='email' name='email' value=content.targetUser.email maxlength='300')
            tr
                td New Password
                td: input(type='password' name='password' autocomplete='new-password' maxlength='50')
            tr
                td Confirm Password
                td: input(type='password' name='passwordcheck' autocomplete='new-password' maxlength='50')
            tr
                td
                td.note
                    | Leave blank to keep current password.
                    if content.passwordRules
                        |  If changing: #{content.passwordRules}

    //- ── Personal details ─────────────────────────────────────────────────────
    fieldset
        legend Personal Details
        table
            tr
                td First Name
                td: input(type='text' name='firstname' value=content.targetUser.firstname maxlength='300')
            tr
                td Last Name
                td: input(type='text' name='lastname' value=content.targetUser.lastname maxlength='300')
            tr
                td Organisation
                td: input(type='text' name='organisation' value=(content.targetUser.organisation || '') maxlength='300')
            tr
                td Telephone
                td: input(type='text' name='telephone' value=(content.targetUser.telephone || '') maxlength='50')
            tr
                td Mobile
                td: input(type='text' name='mobile' value=(content.targetUser.mobile || '') maxlength='50')

    //- ── Postal address ───────────────────────────────────────────────────────
    fieldset
        legend Postal Address
        table
            tr
                td Select Address
                td
                    select(name='postaladdressid' id='postaladdressid-select')
                        if content.addresses && content.addresses.length
                            each addr in content.addresses
                                option(value=addr.addressid selected=(addr.addressid == content.targetUser.postaladdressid))
                                    = addr.address + ', ' + addr.city + ', ' + addr.state
                        option(value='b') + New address below
            tr#new-address-row(style='display:none')
                td(colspan='2')
                    table(style='width:100%')
                        tr
                            td(style='text-align:right; padding-right:12px; width:1%; white-space:nowrap') Address
                            td: input(type='text' name='postaladdress' maxlength='100')
                        tr
                            td(style='text-align:right; padding-right:12px; white-space:nowrap') City
                            td: input(type='text' name='postalcity' maxlength='50')
                        tr
                            td(style='text-align:right; padding-right:12px; white-space:nowrap') State
                            td: input(type='text' name='postalstate' maxlength='20')
                        tr
                            td(style='text-align:right; padding-right:12px; white-space:nowrap') Postcode
                            td: input(type='text' name='postalcode' maxlength='10')
                        tr
                            td(style='text-align:right; padding-right:12px; white-space:nowrap') Country
                            td: input(type='text' name='postalcountry' value='Australia' maxlength='50')

    //- ── Account settings (admin only) ───────────────────────────────────────
    if content.isAdmin
        fieldset
            legend Account Settings
            table
                tr.cb-row
                    td: input(type='checkbox' name='isadmin' value='ON' checked=content.targetUser.admin)
                    td: label Admin
                tr.cb-row
                    td: input(type='checkbox' name='isjudge' value='ON' checked=content.targetUser.judge id='isjudge-cb')
                    td: label Judge
                tr.cb-row
                    td: input(type='checkbox' name='paymentsopen' value='ON' checked=content.targetUser.paymentsopen)
                    td: label Payments Open
                tr.cb-row
                    td: input(type='checkbox' name='enabled' value='ON' checked=content.targetUser.enabled)
                    td: label Enabled
                tr.cb-row
                    td: input(type='checkbox' name='chairperson' value='ON' checked=content.targetUser.chairperson)
                    td: label Chairperson
                tr.cb-row
                    td: input(type='checkbox' name='viewentries' value='ON' checked=content.targetUser.viewentries)
                    td: label Can View Entries
                tr.cb-row
                    td: input(type='checkbox' name='reviewer' value='ON' checked=content.targetUser.reviewer)
                    td: label Reviewer
                tr.cb-row
                    td: input(type='checkbox' name='simplejudge' value='ON' checked=content.targetUser.simplejudge)
                    td: label Simple Judge
                tr.cb-row
                    td: input(type='checkbox' name='onlyjudgepostreview' value='ON' checked=content.targetUser.onlyjudgepostreview)
                    td: label Only Judge Post-Review
                tr.cb-row
                    td: input(type='checkbox' name='exclude' value='ON' checked=content.targetUser.exclude)
                    td: label Exclude from Reports

        if content.targetUser.judge && content.categories && content.categories.length
            fieldset#judge-cats-fieldset
                legend Categories to Judge
                .cat-grid
                    each cat in content.categories
                        label
                            input(type='checkbox' name='categories' value=cat.categoryid checked=cat.judging)
                            = cat.name

    .form-actions
        a.btn-secondary(href='/home?action=users') < Users
        button.btn(type='submit') Save Changes

script(src='/js/user-edit.js')
