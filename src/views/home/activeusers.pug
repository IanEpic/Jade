//- home/activeusers.pug

style.
    .au-wrap { max-width: 600px; margin: 40px auto; text-align: center; }
    .au-wrap h3 { color: #c48f06; font-size: 18px; margin-bottom: 16px; }
    .au-wrap p { color: #aaa; font-size: 13px; margin-bottom: 24px; }
    .au-download-btn { display: inline-block; padding: 10px 28px; background: #c48f06; color: #000; font-weight: 600; font-size: 14px; border-radius: 4px; text-decoration: none; }
    .au-download-btn:hover { background: #d4a017; }
    .au-note { margin-top: 20px; font-size: 12px; color: #666; }

.au-wrap
    h3 Active Users Report
    p All non-excluded users for this program, with last logon and entry counts.
    a.au-download-btn(href='/' + program.slug + '/reportActiveUsers') ⬇ Download Excel
    p.au-note Your download will begin automatically.

script.
    // Auto-trigger download without navigating away from this page
    setTimeout(() => {
        const a = document.createElement('a');
        a.href = window.location.href.replace(/\/home\?action=activeusers.*/, '/reportActiveUsers');
        a.download = '';
        document.body.appendChild(a);
        a.click();
        document.body.removeChild(a);
    }, 400);
