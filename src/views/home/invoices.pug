//- home/invoices.pug
//- Equiv of $invoicestable in home.cgi.

style.
    .invoices-wrap { max-width: 900px; margin: 0 auto; font-size: 14px; }
    .invoices-wrap h2 { text-align: center; color: var(--color-accent-strong); margin-bottom: 20px; }
    .invoices-wrap fieldset { border: 1px solid var(--border); border-radius: 4px; margin-bottom: 14px; padding: 14px 18px; }
    .invoices-wrap legend { font-size: 12px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; color: var(--color-accent-strong); padding: 0 8px; }
    .invoices-table { width: 100%; border-collapse: collapse; }
    .invoices-table th { font-size: 12px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; border-bottom: 1px solid var(--border); padding: 6px 10px; text-align: left; color: var(--color-accent-strong); }
    .invoices-table th.r, .invoices-table td.r { text-align: right; }
    .invoices-table td { padding: 7px 10px; border-bottom: 1px solid var(--border-faint); vertical-align: middle; font-size: 14px; }
    .invoices-table tr:hover td { background: rgba(255,255,255,0.04); }
    .invoices-table .actions { white-space: nowrap; text-align: right; }
    .invoices-table .actions a { margin-left: 8px; font-size: 16px; color: var(--text-arrow); text-decoration: none; }
    .invoices-table .actions a:hover { color: var(--color-accent-strong); }
    .invoices-table .balance-zero { color: #4caf50; }

.invoices-wrap
    h2 Invoices

    fieldset
        legend Invoice History
        table.invoices-table
            thead
                tr
                    th Invoice No
                    th.r Owing
                    th.r Paid
                    th.r Balance
                    th
            tbody
                each inv in content.invoices
                    - let balance = inv.balance || 0
                    -
                        // No deleting a paid invoice (it would orphan the payment).
                        var canDelete = (content.catsOpenForEntries.length || content.overrideOpen.length) && (inv.paid || 0) <= 0;
                    tr
                        td= inv.invoiceid
                        td.r= content.currency(inv.totalamt || 0)
                        td.r= content.currency(inv.paid || 0)
                        td.r(class=(balance <= 0 ? 'balance-zero' : ''))= content.currency(balance)
                        td.actions
                            a(href='/formInvoice?invoiceid=' + inv.invoiceid title='View invoice') 👁
                            if canDelete
                                a(href='/formInvoice?invoiceid=' + inv.invoiceid + '&action=delete' title='Delete invoice' data-confirm='Delete this invoice?' style='color:#c44') ✕
