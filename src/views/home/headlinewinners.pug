//- home/headlinewinners.pug
//- Admin (Judging): choose the winner of each headline award. The nominees are the winners
//- of the categories in the feeder type(s). Selecting a radio saves immediately.

style.
    .hw-wrap { max-width: 720px; margin: 0 auto; }
    .hw-wrap h2 { text-align: center; color: #c48f06; margin-bottom: 6px; }
    .hw-intro { text-align: center; color: #aaa; font-size: 13px; margin: 0 auto 18px; max-width: 640px; line-height: 1.5; }
    .hw-card { border: 1px solid #3a3a3a; border-radius: 6px; margin-bottom: 14px; overflow: hidden; }
    .hw-head { background: #1e1e1e; padding: 9px 14px; font-size: 13px; font-weight: 700; color: #c48f06; border-bottom: 1px solid #333; display: flex; justify-content: space-between; align-items: baseline; }
    .hw-status { font-size: 12px; font-weight: 400; }
    .hw-body { padding: 6px 14px; }
    .hw-opt { display: flex; align-items: center; gap: 9px; padding: 6px 2px; font-size: 13px; color: #ddd; border-bottom: 1px solid #222; cursor: pointer; }
    .hw-opt:last-child { border-bottom: none; }
    .hw-opt input { accent-color: #c48f06; }
    .hw-ft { color: #999; font-size: 12px; }
    .hw-warn { background: #3a2a1a; border-left: 4px solid #c48f06; color: #f0d9a8; padding: 8px 14px; font-size: 13px; }

.hw-wrap
    h2 Headline Award Winners
    p.hw-intro Choose the winner of each headline award from the winners of its feeder categories. Selecting a winner saves immediately and drives the headline citation. Run this once category winners are nominated.

    if !content.headlines || !content.headlines.length
        .hw-warn No headline awards are configured. Set a category type to “feed winners into” a headline category under Admin → Setup → Category Types.
    each h in content.headlines
        .hw-card
            .hw-head
                span= h.category
                span.hw-status(data-headlineid=h.categoryid)
            .hw-body
                if !h.nominees.length
                    .hw-warn No winners recorded in the feeder categories yet.
                each n in h.nominees
                    label.hw-opt
                        input(type='radio' name='hw_' + h.categoryid value=n.entryid data-headlineid=h.categoryid checked=(n.headlinewinner ? true : false))
                        span= n.entrant
                        if n.finalisttext
                            span.hw-ft= '— ' + n.finalisttext

script(src='/js/home-headlinewinners.js?v=' + buildHash)
