//- formPaymentOptions-content.pug

style.
    .invoice-wrap { max-width: 700px; margin: 0 auto; font-size: 14px; }
    .invoice-wrap h2 { text-align: center; color: var(--color-accent-strong); margin-bottom: 20px; }
    .invoice-wrap fieldset { border: 1px solid var(--border); border-radius: 4px; margin-bottom: 14px; padding: 14px 18px; }
    .invoice-wrap legend { font-size: 12px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; color: var(--color-accent-strong); padding: 0 8px; }
    .invoice-wrap table { border-collapse: collapse; width: 100%; }
    .invoice-wrap .entry-table { width: 100%; border-collapse: collapse; margin-top: 8px; }
    .invoice-wrap .entry-table th { font-size: 12px; font-weight: 600; text-transform: uppercase; color: var(--color-accent-strong); border-bottom: 1px solid var(--border); padding: 5px 8px; }
    .invoice-wrap .entry-table th.r, .invoice-wrap .entry-table td.r { text-align: right; }
    .invoice-wrap .entry-table th.c, .invoice-wrap .entry-table td.c { text-align: center; width: 60px; }
    .invoice-wrap .entry-table td { padding: 6px 8px; border-bottom: 1px solid var(--border-faint); }
    .invoice-wrap .eb-note { font-size: 12px; color: var(--color-accent-strong); margin-top: 8px; padding: 6px 10px; border-left: 3px solid var(--color-accent-strong); }
    .invoice-wrap .alert-error { background: var(--err-bg); color: var(--err-text); padding: 8px 12px; margin-bottom: 12px; border-left: 4px solid var(--err-border); }
    .invoice-wrap .form-actions { text-align: center; margin-top: 20px; padding-top: 16px; border-top: 1px solid var(--border-subtle); display: flex; justify-content: center; align-items: center; gap: 10px; flex-wrap: wrap; }
    .invoice-wrap .radio-list p { margin: 10px 0; }
    .invoice-wrap .radio-list label { display: flex; align-items: flex-start; gap: 8px; line-height: 1.5; }
    .invoice-wrap .radio-list input[type=radio] { margin-top: 4px; flex-shrink: 0; }

.invoice-wrap

    h2 Make Payment

    if mode === 'closed'
        p Payments are currently closed.
        .form-actions
            a.btn-secondary(href='/home') Return Home

    else if mode === 'step1'
        if alert
            p.alert-error!= alert

        - let hasInvoices   = unpaidInvoices && unpaidInvoices.length
        - let hasUninvoiced = uninvoicedEntries && uninvoicedEntries.length

        if !hasInvoices && !hasUninvoiced
            p You have nothing for which to pay.
            .form-actions
                a.btn-secondary(href='/home?action=newentry') Create an Entry

        else
            form(method='POST' action='/formPaymentOptions')
                fieldset
                    legend Payment Method
                    .radio-list
                        if hasInvoices
                            p
                                label
                                    input(type='radio' name='pmtoption' value='1')
                                    |  Pay invoices using your credit card
                        if hasUninvoiced
                            p
                                label
                                    input(type='radio' name='pmtoption' value='2')
                                    |  Create an invoice for payment by EFT
                            p
                                label
                                    input(type='radio' name='pmtoption' value='3')
                                    |  Pay for entries now using your credit card (you will receive an invoice at the conclusion of the payment process)
                .form-actions
                    a.btn-secondary(href='/home') Cancel
                    button.btn(type='submit' name='submit' value='Continue') Continue

    else if mode === 'step2'
        if alert
            p.alert-error!= alert

        form(method='POST' action=nextAction)
            input(type='hidden' name='pmtoption' value=pmtoption)
            input(type='hidden' name='form' value='3')

            if caption
                p= caption
            if earlyBird
                p.eb-note
                    | ★ #{earlyBird.name || 'Early Bird Discount'}: your discount will be applied on the next page.

            if pmtoption === 1
                fieldset
                    legend Invoices Requiring Payment
                    table.entry-table
                        thead
                            tr
                                th Invoice No
                                th Owing
                                th Paid
                                th Balance
                                th.c Pay Now
                                th.c Delete
                        tbody
                            each inv in unpaidInvoices
                                - let total = (parseFloat(inv.totalex)||0) + (parseFloat(inv.gst)||0) - (parseFloat(inv.partnerdiscount)||0)
                                - let paid  = parseFloat(inv.paid) || 0
                                - let balance = total - paid
                                - let isPaid = balance <= 0
                                tr
                                    td= inv.invoiceid
                                    td= currency(total)
                                    td= currency(paid)
                                    td= currency(balance)
                                    td.c
                                        input(type='checkbox' name='#INV#' + inv.invoiceid value='ON' checked=!isPaid disabled=isPaid)
                                    td.c
                                        a(href='/formInvoice?invoiceid=' + inv.invoiceid + '&action=delete' data-confirm='Delete this invoice?' title='Delete invoice' style='color:#c44') ✕

            else
                fieldset
                    legend Unpaid Entries
                    table.entry-table
                        thead
                            tr
                                th Entry No
                                th Your Reference
                                th Entrant
                                th Category
                                th.r Cost
                                th.c Add
                        tbody
                            each entry in allEntries
                                - let cost = (parseFloat(entry.costex)||0) + (parseFloat(entry.gst)||0)
                                - let hasInvoice = !!entry.invoiceid
                                - let disabled = hasInvoice || !cost
                                if !disabled
                                    tr
                                        td= entry.entryid
                                        td= entry.userref
                                        td= entry.entrantname
                                        td= entry.categoryname
                                        td.r= currency(cost)
                                        td.c
                                            input(type='checkbox' name='#ENT#' + entry.entryid value='ON' checked=!disabled disabled=disabled)

            .form-actions
                a.btn-secondary(href='/home') Cancel
                button(type='submit' name='submit' value='Continue') Continue
