//- home/allocatejudges.pug
//- Equiv of $allocatejudges in home.cgi — judge↔entry allocation matrix per category.

style.
    .alloc-wrap { max-width: 940px; margin: 0 auto; }
    .alloc-wrap h3 { color: var(--color-accent-strong); font-size: 18px; text-align: center; margin-bottom: 16px; }
    .alloc-cat { border: 1px solid var(--border-faint); border-radius: 4px; margin-bottom: 16px; padding: 12px 16px; }
    .alloc-cat h4 { color: var(--color-accent-strong); font-size: 15px; margin: 0 0 10px; }
    .alloc-table { width: 100%; border-collapse: collapse; }
    .alloc-table th { font-size: 12px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; color: var(--color-accent-strong); border-bottom: 1px solid var(--border); padding: 6px 10px; text-align: left; }
    .alloc-table td { padding: 6px 10px; border-bottom: 1px solid var(--surface-2); font-size: 13px; color: var(--color-muted); vertical-align: middle; }
    .alloc-table tr:hover td { background: rgba(255,255,255,0.03); }
    .alloc-table .judge-col { text-align: center; width: 44px; white-space: nowrap; padding-left: 4px; padding-right: 4px; }
    .alloc-table .id-col { color: var(--text-dim); width: 1%; white-space: nowrap; }
    .alloc-table input[type=checkbox], .alloc-table input[type=radio] { accent-color: var(--color-accent-strong); width: 15px; height: 15px; cursor: pointer; }
    .alloc-table tr.lead-row td, .alloc-table tr.lead-row th { background: var(--surface); border-bottom: 1px solid var(--border-subtle); }
    .alloc-table .lead-label { color: var(--text-arrow); font-weight: 600; text-transform: none; font-size: 12px; }
    .alloc-empty { color: var(--text-dim); font-style: italic; font-size: 13px; padding: 4px 0; }
    .lead-clear { background: none; border: 1px solid var(--border); color: var(--text-arrow); border-radius: 3px; font-size: 11px; padding: 1px 6px; margin-left: 8px; cursor: pointer; vertical-align: middle; }
    .lead-clear:hover { border-color: var(--color-accent); color: var(--color-accent); }
    .alloc-actions { text-align: center; margin-top: 14px; }
    .alloc-actions a, .alloc-actions button { margin: 0 6px; }
    .alloc-table td.conflict { background: #3a1f1f; outline: 1px solid #b5562f; }
    .alloc-table td.conflict::after { content: '⚠'; color: #e7935f; font-size: 11px; display: block; line-height: 0; margin-top: 2px; }
    .alloc-conflict-note { color: #e7935f; font-size: 12px; text-align: center; margin: 0 0 12px; }

.alloc-wrap
    h3 Allocate Judges
    p.alloc-conflict-note ⚠ marks a judge who owns that entry (conflict of interest). Depending on the program’s judging model these cells may be ignored when you save.

    form(method='POST' action='/judgeAllocation')
        each cat in content.cats
            .alloc-cat
                h4= cat.name
                if !cat.judges || !cat.judges.length
                    .alloc-empty No judges assigned to this category yet.
                else if !cat.entries || !cat.entries.length
                    .alloc-empty No entries in this category yet.
                else
                    table.alloc-table
                        thead
                            tr
                                th.id-col Entry
                                th Entrant
                                each judge in cat.judges
                                    th.judge-col(title=(judge.firstname || '') + ' ' + (judge.lastname || ''))= (judge.firstname || '').substring(0, 1) + '.' + (judge.lastname || '').substring(0, 2)
                        tbody
                            tr.lead-row
                                th.lead-label(colspan='2')
                                    | Lead Judge
                                    button.lead-clear(type='button' data-cat=cat.categoryid title='Clear lead judge') Clear
                                each judge in cat.judges
                                    td.judge-col
                                        input(type='radio' name='hj~' + cat.categoryid value=judge.userid checked=(cat.userid === judge.userid))
                            each entry in cat.entries
                                - var displayName = entry.finalisttext || entry.entrantname
                                tr
                                    td.id-col= entry.entryid
                                    td= displayName
                                    each judge in cat.judges
                                        - var isConflict = judge.userid === entry.userid
                                        td.judge-col(class=isConflict ? 'conflict' : '' title=isConflict ? 'This judge owns this entry' : '')
                                            input(type='checkbox' name='judge' value=judge.userid + '~' + entry.entryid checked=(entry.assignedJudgeIds && entry.assignedJudgeIds.has(judge.userid)))

        .alloc-actions
            a.btn-secondary(href='/home') Cancel
            button.btn(type='submit') Save Allocation

script.
    document.querySelectorAll('.lead-clear').forEach(function (b) {
        b.addEventListener('click', function () {
            document.querySelectorAll('input[name="hj~' + b.dataset.cat + '"]').forEach(function (r) { r.checked = false; });
        });
    });
