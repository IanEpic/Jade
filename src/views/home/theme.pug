//- home/theme.pug
//- Admin → Theme (Look & Feel). Brand assets (favicon, doc header) for all programs; for themed
//- programs (1057+) a 5-core-colour editor that derives the full token set (with an Advanced
//- per-token override grid) + live preview.

-
    var themed = content.themed
    var theme = content.theme || {}
    var defaults = content.DEFAULT_TOKENS || {}
    var groups = content.TOKEN_GROUPS || []
    var coreKeys = content.CORE_KEYS || []
    var darkCore = content.DARK_CORE || {}
    var lightCore = content.LIGHT_CORE || {}
    var tokens = Object.assign({}, defaults, theme.tokens || {})
    var inferred = { accent: tokens['color-accent'], bg: tokens['color-bg'], surface: tokens['surface'], text: tokens['color-text'], border: tokens['border'] }
    var core = Object.assign({}, inferred, theme.core || {})
    var bg = theme.background || {}
    var font = theme.font || {}
    var previewStyle = Object.keys(tokens).map(function (k) { return '--' + k + ':' + tokens[k]; }).join(';') + (bg.color ? ';background:' + bg.color : '')

style.
    .theme-page { max-width: 720px; margin: 0 auto; }
    .theme-page h2 { color: var(--color-accent-strong); text-align: center; margin: 0 0 4px; }
    .theme-page .tp-sub { color: var(--text-dim); font-size: 13px; text-align: center; margin: 0 auto 22px; max-width: 580px; line-height: 1.5; }
    .theme-page fieldset { border: 1px solid var(--border-mid); border-radius: 6px; margin-bottom: 18px; padding: 8px 18px 16px; }
    .theme-page legend { font-weight: bold; padding: 0 6px; font-size: 13px; text-transform: uppercase; letter-spacing: .04em; color: var(--color-accent-strong); }
    .theme-page .asset-row { display: flex; align-items: flex-start; gap: 18px; padding: 14px 0; border-bottom: 1px solid var(--border-row); }
    .theme-page .asset-row:last-child { border-bottom: none; }
    .theme-page .asset-label { width: 150px; flex-shrink: 0; font-size: 13px; color: var(--text-label); padding-top: 12px; }
    .theme-page .asset-ctl { flex: 1; }
    .media-box { display: flex; flex-direction: column; gap: 11px; width: 100%; box-sizing: border-box; padding: 14px; background: var(--surface-sunken); border: 1px dashed var(--border-dashed); border-radius: 6px; cursor: pointer; transition: border-color .15s, background .15s; }
    .media-box:hover { border-color: var(--border-mid); }
    .media-box.drag-over { border-color: var(--color-accent-strong); border-style: solid; background: rgba(196,143,6,.07); }
    .media-preview { display: flex; align-items: center; gap: 10px; }
    .media-preview img { width: 30px; height: 30px; object-fit: contain; border-radius: 3px; background: var(--surface-raised); flex-shrink: 0; }
    .media-preview img.on-dark { background: #000; padding: 3px 6px; height: 30px; width: auto; }
    .media-preview .fname { font-size: 13px; color: var(--text-strong); }
    .media-preview .fnone { font-size: 13px; color: var(--text-faint); font-style: italic; }
    .media-actions { display: flex; align-items: center; gap: 8px; flex-wrap: wrap; }
    .media-actions span { font-size: 13px; }
    .media-note { font-size: 12px; color: var(--text-faint); }
    .media-note b { color: var(--text-fainter); font-weight: 600; }
    .field-hint { color: var(--text-dim); font-size: 12px; margin-top: 8px; max-width: 480px; }
    .tp-legacy { background: var(--surface-sunken); border: 1px solid var(--border); border-radius: 6px; padding: 16px 18px; font-size: 13px; color: var(--text-label); line-height: 1.6; }
    .tp-legacy b { color: var(--text-strong); }
    //- Editor
    .tp-toolbar { display: flex; align-items: center; gap: 12px; margin-bottom: 16px; }
    .tp-toolbar .tp-presets { display: flex; align-items: center; gap: 10px; margin-right: auto; }
    .tp-toolbar button { margin: 0; min-width: 64px; }
    .tp-cols { display: flex; gap: 18px; align-items: flex-start; }
    .tp-controls { flex: 1; min-width: 0; }
    .tp-core { display: flex; flex-direction: column; gap: 2px; }
    .tp-row { display: flex; align-items: center; gap: 12px; padding: 6px 0; }
    .tp-row label { flex: 1; font-size: 13px; color: var(--text-label); }
    .tp-row .tp-key { font-family: monospace; font-size: 11px; color: var(--text-faint); }
    .tp-swatch { width: 46px; height: 28px; padding: 0; border: 1px solid var(--border); border-radius: 4px; cursor: pointer; flex-shrink: 0; }
    .tp-text { background: var(--input-bg); color: var(--color-text); border: 1px solid var(--border); border-radius: 3px; padding: 5px 8px; font-size: 12px; width: 100%; box-sizing: border-box; }
    details.tp-adv { margin-top: 12px; }
    details.tp-adv > summary { cursor: pointer; font-size: 12px; color: var(--text-dim); user-select: none; }
    .tp-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(210px, 1fr)); gap: 4px 16px; margin-top: 10px; }
    .tp-grid .tp-cell { display: flex; align-items: center; gap: 8px; padding: 3px 0; }
    .tp-grid .tp-cell span { font-family: monospace; font-size: 11px; color: var(--text-faint); flex: 1; overflow: hidden; text-overflow: ellipsis; }
    .tp-grid .tp-swatch { width: 34px; height: 22px; }
    .tp-sub-row { display: flex; align-items: center; gap: 10px; padding: 6px 0; }
    .tp-sub-row label { width: 150px; flex-shrink: 0; font-size: 12px; color: var(--text-dim); }
    .tp-preview-wrap { width: 280px; flex-shrink: 0; position: sticky; top: 12px; }
    .tp-preview-label { font-size: 11px; text-transform: uppercase; letter-spacing: .04em; color: var(--text-faint); margin-bottom: 6px; }
    #tp-preview { border: 1px solid var(--border-mid); border-radius: 8px; padding: 16px; background-size: cover; background-position: center; }
    @media (max-width: 720px) { .tp-cols { flex-direction: column; } .tp-preview-wrap { width: 100%; position: static; } }

.theme-page
    h2 Theme — Look &amp; Feel
    p.tp-sub Brand assets and (for token-driven programs) the colour scheme, background and fonts of
        |  this program’s portal.

    //- ── Brand assets (all programs) ──────────────────────────────────────────
    fieldset
        legend Brand Assets
        .asset-row
            .asset-label Favicon
            .asset-ctl
                .media-box#favicon-box
                    .media-preview
                        if program.faviconfile
                            img(src='/admin/favicon')
                            span.fname= program.faviconfile
                        else
                            span.fnone Using JADE default
                    .media-actions
                        input(type='file' id='favicon-input' accept='.svg,.png,.ico' style='display:none')
                        button.btn(type='button' id='favicon-btn') Upload Icon
                        if program.faviconfile
                            button.btn-secondary(type='button' id='favicon-delete-btn') Delete
                        span#favicon-status
                    .media-note #[b Drag &amp; drop] an icon here, or click to browse — SVG, PNG or ICO.
        .asset-row
            .asset-label Document header image
            .asset-ctl
                .media-box#docheader-box
                    .media-preview
                        if program.docheaderimage
                            img.on-dark(src='/admin/docheader')
                            span.fname= program.docheaderimage
                        else
                            span.fnone Using program name (text)
                    .media-actions
                        input(type='file' id='docheader-input' accept='.png,.jpg,.jpeg' style='display:none')
                        button.btn(type='button' id='docheader-btn') Upload Image
                        if program.docheaderimage
                            button.btn-secondary(type='button' id='docheader-delete-btn') Delete
                        span#docheader-status
                    .media-note #[b Drag &amp; drop] an image here, or click to browse — PNG or JPG.
                .field-hint Wide logo/banner shown in the header band of the generated Category Documents (PNG/JPG).

    //- ── Look & feel ──────────────────────────────────────────────────────────
    if !themed
        fieldset
            legend Colours, Background &amp; Fonts
            .tp-legacy
                p This program uses the #[b classic template] (year-named HTML shells). The colour /
                    |  background / font editor applies to #[b token-driven] programs, which is the model
                    |  for new programs (2027 onward).
                p(style='margin-bottom:0') Its #[b favicon] and #[b document header image] above still apply.
    else
        .tp-toolbar
            .tp-presets
                span(style='font-size:13px;color:var(--text-label)') Preset:
                button.btn-secondary(type='button' data-preset='dark') Dark
                button.btn-secondary(type='button' data-preset='light') Light
            button.btn#tp-save(type='button') Save Theme
            span#tp-save-status(style='font-size:13px')
        .tp-cols
            .tp-controls
                fieldset
                    legend Core Colours
                    p.field-hint(style='margin:0 0 6px') Pick five colours — the rest of the palette is derived automatically. Fine-tune individual tokens under Advanced.
                    .tp-core
                        each c in coreKeys
                            .tp-row
                                label #{c.label} &nbsp;#[span.tp-key= c.key]
                                input.tp-swatch(type='color' data-core=c.key value=core[c.key])
                    details.tp-adv
                        summary Advanced — override individual tokens
                        each group in groups
                            div(style='margin-top:10px')
                                div(style='font-size:11px;text-transform:uppercase;letter-spacing:.04em;color:var(--text-label);margin-bottom:4px')= group.name
                                .tp-grid
                                    each key in group.keys
                                        .tp-cell
                                            input.tp-swatch(type='color' data-token=key value=tokens[key])
                                            span= key
                fieldset
                    legend Background &amp; Fonts
                    .tp-sub-row
                        label Background colour
                        input.tp-swatch(type='color' data-bg='color' value=(bg.color || tokens['color-bg']))
                    .tp-sub-row
                        label Scrim / overlay
                        input.tp-text(type='text' data-bg='overlay' value=(bg.overlay || '') placeholder='rgba(0,0,0,.45) — over a bg image')
                    .tp-sub-row
                        label Body font
                        input.tp-text(type='text' data-font='body' value=(font.body || '') placeholder='e.g. Inter')
                    .tp-sub-row
                        label Heading font
                        input.tp-text(type='text' data-font='heading' value=(font.heading || '') placeholder='e.g. Poppins')
                    .tp-sub-row
                        label Google Fonts URL
                        input.tp-text(type='text' data-font='googleUrl' value=(font.googleUrl || '') placeholder='https://fonts.googleapis.com/…')
            .tp-preview-wrap
                .tp-preview-label Live preview
                #tp-preview(style=previewStyle)
                    h2(style='color:var(--color-accent-strong);margin:0 0 8px;font-size:18px') Heading
                    p(style='color:var(--color-muted);margin:0 0 10px;font-size:13px') Body text in the muted colour, with a #[a(href='#' style='color:var(--color-link)') link] inside it.
                    div(style='display:flex;gap:8px;margin-bottom:12px;align-items:center;flex-wrap:wrap')
                        button.btn(type='button' onclick='return false') Primary
                        button.btn-secondary(type='button' onclick='return false') Secondary
                        span(style='background:var(--color-accent-strong);color:var(--on-accent);font-size:11px;padding:1px 6px;border-radius:2px') Badge
                    div(style='background:var(--surface);border:1px solid var(--border);border-radius:6px;padding:12px;margin-bottom:12px')
                        div(style='color:var(--text-strong);font-size:13px;font-weight:600;margin-bottom:4px') Surface card
                        div(style='color:var(--text-dim);font-size:12px') Secondary text on a surface.
                    input(type='text' value='Input field' style='background:var(--input-bg);color:var(--color-text);border:1px solid var(--input-border);padding:6px 10px;width:100%;box-sizing:border-box;margin-bottom:10px')
                    div(style='background:#1a4a1a;color:#fff;padding:6px 12px;border-left:4px solid #4caf50;font-size:12px') Status banner

        script(type='application/json' id='tp-data')!= JSON.stringify({ core: core, overrides: theme.overrides || {}, background: bg, font: font, defaults: defaults, darkCore: darkCore, lightCore: lightCore })

script(src='/js/home-theme.js?v=' + buildHash)
