//- viewEntry/editcomment.pug
//- Equiv of $editcommentform — judge editing their comments after commentreview flag set.

form(method='POST' action='/recordScores')
    input(type='hidden' name='entryid' value=entry.entryid)
    input(type='hidden' name='userid'  value=user.userid)
    table(width='600')
        tr(align='left' valign='top')
            th(align='left') Criteria
            th(align='center') Score

        each c in (scorePanel.criteria || [])
            - let myScore = (scorePanel.scores || []).find(s => s.criteriaid === c.criteriaid)
            tr
                td= c.description
                td(align='center')= myScore ? myScore.score : 0
            tr: td(colspan='2'): hr

        tr
            td(colspan='2') &nbsp;
        tr
            td(colspan='2')
                b Entrants consistently tell us that constructive feedback from judges is vitally important to them. Please bear this in mind as you provide your responses below. Your responses will be passed directly to the entrant without editing. Your identity will not be revealed to the entrant (but may be revealed to other judges).
                br
                br
        tr
            td(colspan='2')
                | Please provide a message to the entrant highlighting areas in which this entrant has excelled:
                br
                textarea(name='comment~excel' rows='5' cols='80')= scorePanel.excel
        tr
            td(colspan='2')
                | Please provide a message to the entrant highlighting areas in which this entrant could improve next year:
                br
                textarea(name='comment~improve' rows='5' cols='80')= scorePanel.improve
        tr
            td(colspan='2')
                | Do you have any other constructive comments that may assist this entrant?
                br
                textarea(name='comment~other' rows='5' cols='80')= scorePanel.other
        tr: td(colspan='2'): hr
        tr
            td(colspan='2' align='center')
                button(type='submit') Record Edited Messages
        tr: td(colspan='2'): hr
