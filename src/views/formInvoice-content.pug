//- formInvoice-content.pug

mixin entryTable(entries, totals)
    table.entry-table
        thead
            tr
                th #
                th Your Ref
                th Entrant
                th Category
                th.r Cost
        tbody
            each e in entries
                tr
                    td= e.entryid
                    td= e.userref
                    td= e.entrantname || e.entrantid
                    td= e.categoryname || e.categoryid
                    td.r= '$' + ((parseFloat(e.costex)||0) + (parseFloat(e.gst)||0)).toFixed(2)
            tr
                td(colspan='4') Subtotal
                td.r= '$' + (totals.subtotalEx + totals.subtotalGst).toFixed(2)
            if totals.partnerDiscountInc < 0
                tr.discount-row
                    td(colspan='4') Industry Business Discount
                    td.r= '-$' + Math.abs(totals.partnerDiscountInc).toFixed(2)
            tr.total-row
                td(colspan='4') Total
                td.r= '$' + totals.totalInc.toFixed(2)
        if totals.earlyBirdActive && !totals.isPromoCode
            tr
                td(colspan='5')
                    p.eb-note
                        | Note: #{totals.appliedDiscount && totals.appliedDiscount.name || 'Early Bird Discount'} of $#{totals.ebDiscountInc.toFixed(2)} (incl. $#{(totals.ebDiscountInc / 11).toFixed(2)} GST) applies if paid on or before #{totals.earlyBirdDate}.
                        |  Total payable: $#{totals.totalAfterEb.toFixed(2)}.
        if totals.isPromoCode && totals.earlyBirdActive
            tr
                td(colspan='5')
                    p.eb-note #{totals.appliedDiscount && totals.appliedDiscount.name || 'Promo Code'} discount of $#{totals.ebDiscountInc.toFixed(2)} (incl. $#{(totals.ebDiscountInc / 11).toFixed(2)} GST) applied. Total payable: $#{totals.totalAfterEb.toFixed(2)}.

style.
    .invoice-wrap { max-width: 700px; margin: 0 auto; font-size: 14px; }
    .invoice-wrap h2 { text-align: center; color: var(--color-accent-strong); margin-bottom: 16px; }
    .invoice-wrap fieldset { border: 1px solid var(--border); border-radius: 4px; margin-bottom: 14px; padding: 14px 18px; }
    .invoice-wrap legend { font-size: 12px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; color: var(--color-accent-strong); padding: 0 8px; }
    .invoice-wrap table { border-collapse: collapse; width: 100%; }
    .invoice-wrap .form-table td { padding: 5px 8px; vertical-align: middle; }
    .invoice-wrap .form-table td:first-child { text-align: right; white-space: nowrap; width: 1%; padding-right: 12px; }
    .invoice-wrap .form-table input[type=text], .invoice-wrap .form-table input[type=email] { width: 100%; box-sizing: border-box; }
    .invoice-wrap .entry-table { width: 100%; border-collapse: collapse; margin-top: 8px; }
    .invoice-wrap .entry-table th { font-size: 12px; font-weight: 600; text-transform: uppercase; color: var(--color-accent-strong); border-bottom: 1px solid var(--border); padding: 5px 8px; }
    .invoice-wrap .entry-table th.r, .invoice-wrap .entry-table td.r { text-align: right; }
    .invoice-wrap .entry-table td { padding: 6px 8px; border-bottom: 1px solid var(--border-faint); }
    .invoice-wrap .entry-table .total-row td { border-top: 1px solid var(--border); font-weight: bold; padding-top: 8px; }
    .invoice-wrap .entry-table .discount-row td { color: #4caf50; }
    .invoice-wrap .eb-note { font-size: 12px; color: var(--color-accent-strong); margin-top: 8px; padding: 6px 10px; border-left: 3px solid var(--color-accent-strong); }
    .invoice-wrap .alert-error { background: #7a2a00; color: #fff; padding: 8px 12px; margin-bottom: 12px; border-left: 4px solid #c44; }
    .invoice-wrap .form-actions { text-align: center; margin-top: 20px; padding-top: 16px; border-top: 1px solid var(--border-subtle); display: flex; justify-content: center; align-items: center; gap: 10px; flex-wrap: wrap; }
    .invoice-wrap .invoice-header { display: flex; justify-content: space-between; margin-bottom: 16px; }
    .invoice-wrap .invoice-header .from { text-align: right; font-size: 13px; }
    .invoice-wrap .invoice-meta { font-size: 13px; color: var(--text-arrow); margin-bottom: 12px; }
    .invoice-wrap .rich-text { font-size: 13px; margin-top: 12px; padding-top: 12px; border-top: 1px solid var(--border-subtle); }
    .invoice-wrap .new-addr { margin-top: 8px; }
    .invoice-wrap .new-addr table td:first-child { width: 80px; }

.invoice-wrap

    if error
        p.alert-error= error
    if emailed
        p(style='background:#1a4a1a; color:#fff; padding:8px 12px; border-left:4px solid #4caf50; margin-bottom:12px') ✓ Invoice emailed to #{emailSentTo}

    if isNew
        //- ── Invoice creation form ────────────────────────────────────────────
        h2 Create Invoice

        form(method='POST' action='/formInvoice')
            //- Pass entry IDs through
            each eid in entryIds
                input(type='hidden' name='#ENT#' + eid value='ON')
            input(type='hidden' name='submit' value='Create Invoice')
            input(type='hidden' name='status' value=status)

            fieldset
                legend Invoice Details
                table.form-table
                    tr
                        td Invoice To
                        td: input(type='text' name='invoicee' value=invoicee maxlength='300')
                    tr
                        td Email To
                        td: input(type='email' name='email' value=email maxlength='300')
                    if hasPromoCodes
                        tr
                            td Promo Code
                            td: input(type='text' name='promocode' value=promoCode placeholder='Optional discount code' maxlength='50' style='width:200px')
                    tr
                        td Postal Address
                        td
                            select(name='postaladdressid')
                                option(value='a') — Please Select —
                                each addr in addresses
                                    option(value=addr.addressid selected=(addr.addressid == user.postaladdressid))
                                        = addr.address + ', ' + addr.city + ', ' + addr.state
                                option(value='b') + New address below
                    tr#new-addr-row(style='display:none')
                        td
                        td.new-addr
                            table
                                tr
                                    td Address
                                    td: input(type='text' name='postaladdress' maxlength='100')
                                tr
                                    td City
                                    td: input(type='text' name='postalcity' maxlength='50')
                                tr
                                    td State
                                    td: input(type='text' name='postalstate' maxlength='20')
                                tr
                                    td Postcode
                                    td: input(type='text' name='postalcode' maxlength='10')
                                tr
                                    td Country
                                    td: input(type='text' name='postalcountry' value='Australia' maxlength='50')

            fieldset
                legend Items
                +entryTable(entries, totals)

            .form-actions
                a.btn-secondary(href='/home') Cancel
                button(type='submit') Create Invoice

    else
        //- ── Completed invoice view ───────────────────────────────────────────
        h2 Tax Invoice

        .invoice-header
            div
                p: strong= invoice.invoicee
                if address
                    p= address.address
                    p= address.city + ' ' + address.state + ' ' + address.code
                    p= address.country
            .from!= program.invoicefromtext

        .invoice-meta
            | Date: #{new Date(invoice.date).toLocaleDateString('en-AU')}
            |  &nbsp;|&nbsp; Invoice No: #{invoiceNo}

        fieldset
            legend Items
            +entryTable(entries, totals)

        if pmtInstructions
            .rich-text!= pmtInstructions

        if remittance
            .rich-text!= remittance

        if !forEmail
            .form-actions
                a.btn-secondary(href='/home') Home
                button.btn-secondary(type='button' data-action='show-email-modal') 📧 Email Invoice
                button.btn-secondary(type='button' data-action='print') 🖨 Print
                a.btn-danger(href='/formInvoice?invoiceid=' + invoice.invoiceid + '&action=delete' data-confirm='Delete this invoice?') 🗑 Delete

            //- Email modal
            #email-modal(style='display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.7); z-index:1000; align-items:center; justify-content:center;')
                div(style='background:var(--surface); border:1px solid var(--border); border-radius:4px; padding:24px; width:400px; max-width:90%;')
                    p(style='color:var(--color-accent-strong); font-weight:bold; margin-bottom:12px') Email Invoice
                    form(method='POST' action='/formInvoice?action=email')
                        input(type='hidden' name='invoiceid' value=invoice.invoiceid)
                        p(style='font-size:13px; margin-bottom:8px') Send to:
                        input#email-input(type='email' name='emailto' value=invoice.email style='width:100%; box-sizing:border-box; background:var(--surface-deep); color:var(--color-text); border:1px solid var(--border); padding:8px; font-size:14px; margin-bottom:14px;')
                        div(style='display:flex; gap:10px; justify-content:flex-end;')
                            button.btn-secondary(type='button' data-action='hide-email-modal') Cancel
                            button.btn(type='submit') Send

script(src='/js/form-invoice.js?v=' + buildHash)
