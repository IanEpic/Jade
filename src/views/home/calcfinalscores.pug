-
    var slug           = program.slug
    var baseUrl        = '/' + slug + '/home?action=calcfinalscores'
    var ignoreReady    = content.ignoreReady
    var ignoreQs       = ignoreReady ? '&ignoreScoreReady=1' : ''

h2 Calculate Final Scores

if content.wrote
    div(style='background:#1a4a1a; border-left:4px solid #4c4; color:#cfc; padding:10px 14px; font-size:13px; margin-bottom:14px;')
        | Final scores written to database (#{content.rowCount} entries).

p
    | This page runs the final score calculation for all score-ready categories in this program.
    | It shows a preview before writing.

div(style='margin-bottom:12px;')
    label
        input(type='checkbox' id='ignoreReady' onchange="location.href='"+baseUrl+"'+(this.checked?'&ignoreScoreReady=1':'')")
        |  Include categories where Score Ready is not set (for validation)

if !content.preview.length
    p(style='color:#aaa;') No scored entries found for this program#{ ignoreReady ? '' : ' with Score Ready categories' }.

else
    p Found #{content.preview.length} entries across score-ready categories.

    - var maxDiff = content.preview.reduce((m,r) => r.diff !== null ? Math.max(m, Math.abs(r.diff)) : m, 0)

    if content.preview.some(r => r.existingScore !== null)
        p(style='color:#aaa; font-size:12px;')
            | Max difference from existing scores: #{maxDiff.toFixed(4)}

    table.data-table(style='width:100%; font-size:12px;')
        thead
            tr
                th Category
                th Entrant
                th New Score
                th Existing Score
                th Diff
        tbody
            each r in content.preview
                tr
                    td= r.categoryname
                    td= r.entrantname
                    td= r.finalscore.toFixed(4)
                    td= r.existingScore !== null ? r.existingScore.toFixed(4) : '—'
                    td(style=(r.diff !== null && Math.abs(r.diff) > 0.001 ? 'color:#f88;' : ''))= r.diff !== null ? r.diff.toFixed(4) : '—'

    div(style='margin-top:16px;')
        form(method='POST' action=baseUrl+'&confirm=1'+ignoreQs style='display:inline;')
            button.btn(type='submit') Write Final Scores to Database
        |
        a.btn-secondary(href='/' + slug + '/home?action=program') Cancel
