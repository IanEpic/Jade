//- partials/entrant_fields.pug
//- Replaces entrant_fields.ejs — included inside entry/form.pug
//- Variables available from parent: user, addresses

table
    tr
        td Entrant Name
        td: input(type='text' name='name' size='50' maxlength='300')

    tr
        td Entrant Type
        td
            select(name='type')
                option Individual
                option Business
                option Company

    tr
        td Company Name (if applicable)
        td: input(type='text' name='legalentity' size='50' maxlength='300')

    //- Street address selector — replaces $address_popup('streetaddressid')
    if addresses && addresses.length
        tr
            td Select a Street Address
            td
                select(name='streetaddressid')
                    option(value='a') ------ Please Select ------
                    option(value='b') New Address Below
                    each addr in addresses
                        option(value=addr.addressid) #{addr.address}, #{addr.city}, #{addr.state}

    //- New street address fields — replaces $address_table('street')
    tr
        td(valign='top')= addresses && addresses.length ? '' : 'Enter a Street Address'
        td
            table#street-address-fields
                tr
                    td Address
                    td: input(type='text' name='streetaddress' size='50' maxlength='100')
                tr
                    td City
                    td: input(type='text' name='streetcity' size='50' maxlength='50')
                tr
                    td State
                    td: input(type='text' name='streetstate' size='20' maxlength='20')
                tr
                    td Postcode
                    td: input(type='text' name='streetcode' size='10' maxlength='10')
                tr
                    td Country
                    td: input(type='text' name='streetcountry' size='50' maxlength='50' value='Australia')

    //- Postal address selector — replaces $address_popup('postaladdressid', ..., 'aboveoption')
    if addresses && addresses.length
        tr
            td Select a Postal Address
            td
                select(name='postaladdressid')
                    option(value='a') ------ Please Select ------
                    option(value='b') New Address Below
                    option(value='c') Same as above
                    each addr in addresses
                        option(value=addr.addressid) #{addr.address}, #{addr.city}, #{addr.state}

    //- New postal address fields
    tr
        td(valign='top')= addresses && addresses.length ? '' : 'Enter a Postal Address'
        td
            table#postal-address-fields
                tr
                    td Address
                    td: input(type='text' name='postaladdress' size='50' maxlength='100')
                tr
                    td City
                    td: input(type='text' name='postalcity' size='50' maxlength='50')
                tr
                    td State
                    td: input(type='text' name='postalstate' size='20' maxlength='20')
                tr
                    td Postcode
                    td: input(type='text' name='postalcode' size='10' maxlength='10')
                tr
                    td Country
                    td: input(type='text' name='postalcountry' size='50' maxlength='50' value='Australia')

    tr
        td Telephone
        td: input(type='text' name='telephone' size='50' maxlength='50' value=user.telephone || '')

    tr
        td Mobile
        td: input(type='text' name='mobile' size='50' maxlength='50' value=user.mobile || '')

    tr
        td Email
        td: input(type='text' name='email' size='50' maxlength='100' value=user.email || '')

script(src='/js/jade.js?v=' + buildHash)
script(src='/js/form-entry.js?v=' + buildHash)
