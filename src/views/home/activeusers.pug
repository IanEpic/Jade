//- home/activeusers.pug

style.
    .rpt-wrap { max-width: 960px; margin: 0 auto; }
    .rpt-wrap h3 { color: var(--color-accent-strong); font-size: 18px; text-align: center; margin-bottom: 6px; }
    .rpt-wrap .rpt-desc { color: var(--text-arrow); font-size: 13px; text-align: center; margin-bottom: 16px; }
    .rpt-table { width: 100%; border-collapse: collapse; font-size: 13px; }
    .rpt-table th { font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; border-bottom: 1px solid var(--border); padding: 6px 8px; text-align: left; color: var(--color-accent-strong); white-space: nowrap; }
    .rpt-table th.num { text-align: right; }
    .rpt-table td { padding: 6px 8px; border-bottom: 1px solid var(--border-faint); vertical-align: middle; }
    .rpt-table td.num { text-align: right; color: var(--color-muted); }
    .rpt-table tr:hover td { background: rgba(255,255,255,0.04); }
    .rpt-actions { text-align: center; margin-top: 20px; }

.rpt-wrap
    h3 Active Users
    p.rpt-desc All non-excluded users for this program, with last logon and entry counts.

    if content.rows && content.rows.length
        - var totStarted   = content.rows.reduce(function(s,r){ return s + (r.started   || 0); }, 0)
        - var totPaid      = content.rows.reduce(function(s,r){ return s + (r.paid      || 0); }, 0)
        - var totFinalised = content.rows.reduce(function(s,r){ return s + (r.finalised || 0); }, 0)
        table.rpt-table
            thead
                tr
                    th Email
                    th First Name
                    th Last Name
                    th Organisation
                    th Last Logon
                    th.num Started
                    th.num Paid
                    th.num Finalised
            tbody
                each r in content.rows
                    tr
                        td= r.email || ''
                        td= r.firstname || ''
                        td= r.lastname || ''
                        td= r.organisation || ''
                        td= r.LastLogon ? new Date(r.LastLogon).toLocaleDateString('en-AU') : '—'
                        td.num= r.started
                        td.num= r.paid
                        td.num= r.finalised
            tfoot
                tr
                    td(colspan='5' style='font-weight:600; color:var(--color-accent-strong); border-top:2px solid var(--border);') Total
                    td.num(style='font-weight:600; color:var(--color-accent-strong); border-top:2px solid var(--border);')= totStarted
                    td.num(style='font-weight:600; color:var(--color-accent-strong); border-top:2px solid var(--border);')= totPaid
                    td.num(style='font-weight:600; color:var(--color-accent-strong); border-top:2px solid var(--border);')= totFinalised
    else
        p(style='color:var(--text-dim); text-align:center; margin-top:24px;') No users found.

    .rpt-actions
        a.btn(href='/' + program.slug + '/reportActiveUsers') ⬇ Download Excel
