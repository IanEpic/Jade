//- home/questions.pug

style.
    .q-wrap { max-width: 900px; margin: 0 auto; }
    .q-wrap h3 { color: #c48f06; font-size: 18px; text-align: center; margin-bottom: 16px; }
    .q-table { border-collapse: collapse; width: 100%; }
    .q-table th { font-size: 11px; text-transform: uppercase; color: #c48f06; border-bottom: 1px solid #555; padding: 4px 8px; text-align: left; white-space: nowrap; }
    .q-table td { padding: 5px 8px; border-bottom: 1px solid #1e1e1e; vertical-align: middle; }
    .q-table .q-text { font-size: 11px; color: #fff; }
    .q-table .q-desc { font-size: 11px; color: #888; margin-top: 2px; }
    .q-table .q-actions a { margin-right: 10px; font-size: 12px; }
    .q-table .q-type { font-size: 10px; background: #333; color: #bbb; border-radius: 3px; padding: 1px 6px; white-space: nowrap; }
    .q-table input[type=text] { background: #111; color: #eee; border: 1px solid #555; padding: 3px 5px; border-radius: 3px; width: 45px; text-align: center; }
    .q-toolbar { display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px; }
    .q-toolbar a { font-size: 13px; white-space: nowrap; margin-left: 12px; }
    #q-list-search { flex: 1; max-width: 320px; padding: 6px 10px; background: #111; color: #fff; border: 1px solid #555; font-size: 14px; }
    #q-list-search:focus { border-color: #c48f06; outline: none; }
    .q-table tr.hidden { display: none; }

.q-wrap
    h3 Manage Questions

if content.success
    p(style='background:#1a4a1a; color:#fff; padding:8px 12px; border-left:4px solid #4caf50; margin-bottom:14px') Saved.

form(method='POST' action='/formQuestion')
    input(type='hidden' name='type' value=content.type)
    input(type='hidden' name='task' value='reorder')

    .q-toolbar
        input#q-list-search(type='text' placeholder='Search questionsâ€¦' data-filter='.q-table tbody tr')
        a#btn-new-q(href='#') + New Question

    div#new-q-form(style='display:none; margin-bottom:16px; padding:12px; background:#111; border:1px solid #555; border-radius:4px; max-width:600px')
        table(style='width:100%')
            tr
                td(style='white-space:nowrap; padding-right:8px; width:1%; vertical-align:top; padding-top:6px') Question text
                td: input#new-q-text(type='text' style='width:100%; box-sizing:border-box')
            tr
                td(style='padding-right:8px; padding-top:6px; vertical-align:top; padding-top:6px') Description
                td(style='padding-top:6px'): textarea#new-q-desc(rows='2' style='width:100%; box-sizing:border-box')
            tr
                td(style='padding-right:8px; padding-top:6px') Type
                td(style='padding-top:6px')
                    select#new-q-type
                        option(value='text') Text field
                        option(value='textarea') Text area
                        option(value='select') Dropdown
                        option(value='radio') Radio buttons
                        option(value='checkbox') Checkbox
                        option(value='upload') File upload
                        option(value='image') Image upload
                        option(value='video') Video upload
                        option(value='noinput') No input (heading/text)
            tr#new-q-options-row(style='display:none')
                td(style='padding-right:8px; padding-top:6px; vertical-align:top') Options
                td(style='padding-top:6px')
                    textarea#new-q-options(rows='4' style='width:100%; box-sizing:border-box' placeholder='One option per line')
                    div(style='font-size:11px; color:#888; margin-top:2px') Enter each option on a new line
        div(style='margin-top:10px; display:flex; gap:8px; align-items:center')
            button#new-q-save.btn(type='button') Add Question
            a#new-q-cancel.btn-secondary(href='#') Cancel
            span#new-q-error(style='color:#c44; font-size:12px; display:none')

    table.q-table
        thead
            tr
                th #
                th Question
                th Type
                th Order
                th

        tbody
            each q, i in content.questions
                tr
                    td(style='color:#888; width:30px')= q.questionid
                    td
                        div.q-text= q.questiontext
                        if q.description
                            div.q-desc= q.description
                    td: span.q-type= q.questiontype || 'â€”'
                    td: input(type='text' name='#' + q.questionid value=i+1)
                    td.q-actions
                        a(href='/home?action=questions&type=' + content.type + '&questionid=' + q.questionid title='Edit') âœï¸
                        a(href='/formQuestion?questionid=' + q.questionid + '&action=delete' data-confirm='Delete question ' + q.questionid + '?' title='Delete' style='color:#c44') âœ•

    div(style='margin-top:12px')
        button.btn(type='submit') Reorder

script(src='/js/jade.js?v=' + buildHash)
script(src='/js/home-questions.js?v=' + buildHash)
