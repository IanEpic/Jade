//- login-content.pug — two-step login

- let slug         = program ? program.slug : ''
- let checkUrl     = '/' + slug + '/login/check-email'
- let signupUrl    = '/' + slug + '/login/signup'
- let loginUrl     = '/' + slug + '/login'
- let resetUrl     = '/' + slug + '/password-reset'

- let loginText  = (program && program.loginpagetext) || ''
- let marker     = '&lt;~form~&gt;'
- let markerIdx  = loginText.indexOf(marker)
- let textBefore = markerIdx !== -1 ? loginText.substring(0, markerIdx) : loginText
- let textAfter  = markerIdx !== -1 ? loginText.substring(markerIdx + marker.length) : ''

if textBefore
    != textBefore

if message
    div.alert.alert-info= message

if form
    //- Config block read by JS
    div#login-config(style='display:none'
        data-check-url=checkUrl
        data-signup-url=signupUrl
        data-login-url=loginUrl
        data-reset-url=resetUrl)

    //- ── Step 1: Email ────────────────────────────────────────────────────────
    div#step-email
        form#form-email(autocomplete='on')
            table
                tr
                    td(colspan='2'): input#login-email(type='email' name='email' size='40' maxlength='300' autocomplete='email' placeholder='Please enter your email address' value=locals.loginEmail || '')
                tr
                    td(colspan='2'): button#btn-continue(type='submit' style='padding:8px 40px; font-size:1em;') Continue
                tr: td(colspan='2')
                    div#email-error(style='color:#c0392b; margin-top:6px; display:none;')

    //- ── Step 2a: Password ────────────────────────────────────────────────────
    div#step-password(style='display:none;')
        form#form-password(method='POST' action=loginUrl autocomplete='on')
            input#pw-email(type='hidden' name='email' value=locals.loginEmail || '')
            table
                tr: td(colspan='2')
                    span#password-greeting
                tr: td(colspan='2', style='padding-top:12px;')
                tr
                    td(colspan='2'): input#login-password(type='password' name='password' size='40' maxlength='50' autocomplete='current-password' placeholder='Password')
                tr
                    td(colspan='2'): button(type='submit' style='padding:8px 40px; font-size:1em;') Log In
                tr: td(colspan='2')
                    div#password-error(style='color:#c0392b; margin-top:6px; display:none;')
                    if errors && errors.length
                        each e in errors
                            p(style='color:#c0392b; margin:4px 0;')= e
        div(style='margin-top:10px; font-size:0.85em; color:#aaa; text-align:center;')
            div
                a#reset-link(href=resetUrl style='color:#aaa;') Forgot your password?
                span(style='margin:0 8px;') ·
                a(href='#' id='btn-back-from-pw' style='color:#aaa;') Use a different email

    //- ── Step 2b: Sign up ─────────────────────────────────────────────────────
    style.
        #form-signup input[type=text] { width: 200px !important; }
    div#step-signup(style='display:none;')
        p#signup-intro
        form#form-signup(autocomplete='on' style='width:340px; margin:0 auto; text-align:left;')
            input#signup-email(type='hidden' name='email' value='')
            div(style='display:flex; align-items:center; margin-bottom:6px;')
                label(style='width:130px; flex-shrink:0;') First name
                input#signup-firstname(type='text' name='firstname' maxlength='100' autocomplete='given-name' required style='width:200px !important;')
            div(style='display:flex; align-items:center; margin-bottom:6px;')
                label(style='width:130px; flex-shrink:0;') Last name
                input#signup-lastname(type='text' name='lastname' maxlength='100' autocomplete='family-name' required style='width:200px !important;')
            div(style='display:flex; align-items:center; margin-bottom:6px;')
                label(style='width:130px; flex-shrink:0;') Mobile
                input(type='text' name='mobile' maxlength='50' autocomplete='tel' style='width:200px !important;')
            div(style='display:flex; align-items:center; margin-bottom:6px;')
                label(style='width:130px; flex-shrink:0;') Password
                input(type='password' name='password' maxlength='100' autocomplete='new-password' required style='width:200px !important;')
            div(style='display:flex; align-items:center; margin-bottom:6px;')
                label(style='width:130px; flex-shrink:0;') Confirm password
                input(type='password' name='password2' maxlength='100' autocomplete='new-password' required style='width:200px !important;')
            p(style='font-size:0.85em; color:#aaa; margin:4px 0 10px;')= passwordRules || ''
            hr
            div(style='text-align:center;')
                div(style='margin-bottom:6px;')
                    label
                        input(type='checkbox' name='tc' id='signup-tc' required)
                        |  I agree to the terms and conditions
                div#signup-error(style='color:#c0392b; margin-top:6px; display:none;')
                button#btn-signup(type='submit' style='margin-top:6px;') Create Account
            br
            a(href='#' id='btn-back-from-signup') Use a different email

    //- ── Step 3: Signup success ───────────────────────────────────────────────
    div#step-done(style='display:none;')
        p#done-message
        a(href='#' id='btn-back-from-done') ← Back to login

    //- ── Step 4: Account disabled ─────────────────────────────────────────────
    div#step-disabled(style='display:none;')
        p Your account has been disabled. Please contact the program administrator for assistance.
        a(href='#' id='btn-back-from-disabled') Use a different email

if textAfter
    div(style='margin-top:16px;')
        != textAfter

script.
    (function () {
        var cfg         = document.getElementById('login-config');
        var CHECK_URL   = cfg.dataset.checkUrl;
        var SIGNUP_URL  = cfg.dataset.signupUrl;
        var RESET_URL   = cfg.dataset.resetUrl;

        var steps = ['email','password','signup','done','disabled'];

        function show(name) {
            steps.forEach(function(s) {
                var el = document.getElementById('step-' + s);
                if (el) el.style.display = (s === name) ? '' : 'none';
            });
        }

        function setError(id, msg) {
            var el = document.getElementById(id);
            if (!el) return;
            el.textContent = msg;
            el.style.display = msg ? '' : 'none';
        }

        // ── Step 1: email check ──────────────────────────────────────────────
        var formEmail = document.getElementById('form-email');
        formEmail.addEventListener('submit', function(e) {
            e.preventDefault();
            var email = document.getElementById('login-email').value.trim();
            if (!email) { setError('email-error', 'Please enter your email address.'); return; }
            setError('email-error', '');

            var btn = document.getElementById('btn-continue');
            btn.disabled = true;
            btn.textContent = 'Checking…';

            fetch(CHECK_URL, {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded', 'X-Requested-With': 'XMLHttpRequest' },
                body: 'email=' + encodeURIComponent(email),
            })
            .then(function(r) { return r.json(); })
            .then(function(data) {
                btn.disabled = false;
                btn.textContent = 'Continue →';

                if (data.status === 'password' || data.status === 'added') {
                    document.getElementById('pw-email').value = email;
                    var greeting = document.getElementById('password-greeting');
                    if (data.status === 'added') {
                        greeting.textContent = 'Welcome, ' + (data.name || email) + '! We\'ve added you to this program. Please enter your password to continue.';
                    } else {
                        greeting.textContent = 'Welcome back' + (data.name ? ', ' + data.name : '') + '! Please enter your password.';
                    }
                    document.getElementById('reset-link').href = RESET_URL + '?email=' + encodeURIComponent(email);
                    show('password');
                    document.getElementById('login-password').focus();

                } else if (data.status === 'signup') {
                    document.getElementById('signup-email').value = email;
                    document.getElementById('signup-intro').textContent = 'No account found for ' + email + '. Fill in the details below to create one.';
                    show('signup');
                    document.getElementById('signup-firstname').focus();

                } else if (data.status === 'disabled') {
                    show('disabled');

                } else {
                    setError('email-error', data.message || 'Something went wrong. Please try again.');
                }
            })
            .catch(function() {
                btn.disabled = false;
                btn.textContent = 'Continue →';
                setError('email-error', 'Could not connect. Please try again.');
            });
        });

        // ── Step 2b: signup ──────────────────────────────────────────────────
        var formSignup = document.getElementById('form-signup');
        formSignup.addEventListener('submit', function(e) {
            e.preventDefault();
            var tc = document.getElementById('signup-tc');
            if (!tc.checked) {
                setError('signup-error', 'Please accept the terms and conditions.');
                return;
            }
            setError('signup-error', '');

            var btn = document.getElementById('btn-signup');
            btn.disabled = true;
            btn.textContent = 'Creating account…';

            var data = new URLSearchParams(new FormData(formSignup)).toString();
            fetch(SIGNUP_URL, {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded', 'X-Requested-With': 'XMLHttpRequest' },
                body: data,
            })
            .then(function(r) { return r.json(); })
            .then(function(result) {
                btn.disabled = false;
                btn.textContent = 'Create Account';
                if (result.ok && result.redirect) {
                    window.location.href = result.redirect;
                } else if (result.ok) {
                    document.getElementById('done-message').textContent = 'Account created! Please check your email to activate your account before logging in.';
                    show('done');
                } else {
                    setError('signup-error', result.error || 'Something went wrong. Please try again.');
                }
            })
            .catch(function() {
                btn.disabled = false;
                btn.textContent = 'Create Account';
                setError('signup-error', 'Could not connect. Please try again.');
            });
        });

        // ── Back links ───────────────────────────────────────────────────────
        ['btn-back-from-pw','btn-back-from-signup','btn-back-from-done','btn-back-from-disabled'].forEach(function(id) {
            var el = document.getElementById(id);
            if (el) el.addEventListener('click', function(e) {
                e.preventDefault();
                // Clear any server-rendered errors from the password step
                document.querySelectorAll('#step-password p[style*="color:#c0392b"]').forEach(function(p) { p.remove(); });
                setError('password-error', '');
                document.getElementById('login-password').value = '';
                show('email');
                document.getElementById('login-email').focus();
            });
        });

        // ── If returning after a failed password POST, go straight to step 2 ─
        var pwEmail = document.getElementById('pw-email').value;
        if (pwEmail) {
            var greeting = document.getElementById('password-greeting');
            greeting.textContent = 'Please enter your password for ' + pwEmail + '.';
            show('password');
        }
    })();
