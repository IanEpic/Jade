//- home/payments.pug
//- Equiv of $paymentstable in home.cgi.

style.
    .payments-wrap { max-width: 900px; margin: 0 auto; font-size: 14px; }
    .payments-wrap h2 { text-align: center; color: #c48f06; margin-bottom: 20px; }
    .payments-wrap fieldset { border: 1px solid #555; border-radius: 4px; margin-bottom: 14px; padding: 14px 18px; }
    .payments-wrap legend { font-size: 12px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; color: #c48f06; padding: 0 8px; }
    .payments-table { width: 100%; border-collapse: collapse; }
    .payments-table th { font-size: 12px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; border-bottom: 1px solid #555; padding: 6px 10px; text-align: left; color: #c48f06; }
    .payments-table th.r, .payments-table td.r { text-align: right; }
    .payments-table td { padding: 7px 10px; border-bottom: 1px solid #2a2a2a; vertical-align: middle; font-size: 14px; }
    .payments-table tr:hover td { background: rgba(255,255,255,0.04); }
    .payments-table .status-ok { color: #4caf50; }

.payments-wrap
    h2 Payments

    fieldset
        legend Payment History
        if content.payments && content.payments.length
            table.payments-table
                thead
                    tr
                        th Receipt No
                        th Date
                        th Method
                        th.r Amount
                        th Status
                tbody
                    each pmt in content.payments
                        if !pmt.ewayCardNumber || (pmt.ewayCardNumber && pmt.ewayTrxnStatus)
                            - var pmtNo = (content.program.invoicenoprecursor || '') + String(pmt.paymentid).padStart(5, '0')
                            tr
                                td= pmtNo
                                td= new Date(pmt.date).toLocaleDateString('en-AU')
                                td= pmt.method
                                td.r= content.currency(pmt.amount || 0)
                                td.status-ok ✓ Paid
        else
            p(style='color:#888; font-size:13px') No payments recorded.
