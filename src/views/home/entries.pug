//- home/entries.pug
//- Equiv of $entriestable in home.cgi.

style.
    .entries-wrap { max-width: 900px; margin: 0 auto; font-size: 14px; }
    .entries-wrap h2 { text-align: center; color: var(--color-accent-strong); margin-bottom: 20px; }
    .entries-wrap fieldset { border: 1px solid var(--border); border-radius: 4px; margin-bottom: 14px; padding: 14px 18px; }
    .entries-wrap legend { font-size: 12px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; color: var(--color-accent-strong); padding: 0 8px; }
    .entries-intro { font-size: 13px; color: var(--text-arrow); margin-bottom: 14px; padding: 10px 14px; border-left: 3px solid var(--border); background: rgba(255,255,255,0.03); }
    .entries-table { width: 100%; border-collapse: collapse; }
    .entries-table th { font-size: 12px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; border-bottom: 1px solid var(--border); padding: 6px 10px; text-align: left; color: var(--color-accent-strong); }
    .entries-table td { padding: 7px 10px; border-bottom: 1px solid var(--border-faint); vertical-align: middle; font-size: 14px; }
    .entries-table tr:hover td { background: rgba(255,255,255,0.04); }
    .entries-table .status-paid { color: #4caf50; }
    .entries-table .status-invoiced { color: var(--color-accent-strong); }
    .entries-table .status-unpaid { color: var(--text-arrow); }
    .entries-table .actions { white-space: nowrap; }
    .entries-table .actions a { margin-right: 6px; font-size: 16px; color: var(--text-arrow); text-decoration: none; }
    .entries-table .actions a:hover { color: var(--color-accent-strong); }
    .entries-footer { margin-top: 20px; padding-top: 16px; border-top: 1px solid var(--border-subtle); display: flex; justify-content: flex-end; }

.entries-wrap
    h2 My Entries

    if content.program.costexplanationtext
        .entries-intro!= content.program.costexplanationtext

    fieldset
        legend Entries
        table.entries-table
            thead
                tr
                    th #
                    th= content.entrantLabel || 'Entrant'
                    th Category
                    th Your Ref
                    th Cost
                    th Status
                    th(style='width:80px')
            tbody
                each entry in content.entries
                    - let cost = (parseFloat(entry.effcostex) || 0) + (parseFloat(entry.effgst) || 0)
                    //- Once a discount has been applied to the invoice (at payment time),
                    //- prorate it back onto this entry so the cost shows the post-discount amount.
                    - let invEb = parseFloat(entry.invebdiscount) || 0
                    - let invTotal = parseFloat(entry.invtotalcost) || 0
                    - let netCost = (invEb > 0 && invTotal > 0) ? cost - (invEb * cost / invTotal) : cost
                    - let costDisplay = cost === 0 ? '' : content.currency(netCost)
                    - let pmt = entry.entryaccepted ? 'Paid' : (entry.invoiceid && !entry.invoicedeleted ? 'Invoiced' : 'Unpaid')
                    - let finalisedLabel = entry.finalised ? ' · Finalised' : ' · Editing'
                    - let statusClass = entry.entryaccepted ? 'status-paid' : (entry.invoiceid && !entry.invoicedeleted ? 'status-invoiced' : 'status-unpaid')
                    - let catOpen = content.catsOpenForEntries.some(c => c.categoryid === entry.categoryid)
                    - let canEdit = (entry.entryopen || catOpen) && !entry.finalised
                    tr
                        td= entry.entryid
                        td= entry.entrantname
                        td= entry.categoryname
                        td= entry.userref
                        td= costDisplay
                        td(class=statusClass)= pmt + finalisedLabel
                        td.actions
                            a(href='/viewEntry?entryid=' + entry.entryid title='View') 👁
                            if canEdit
                                a(href='/formEntry?entryid=' + entry.entryid title='Edit') ✏️
                                a(href='/entry/' + entry.entryid + '/delete' title='Delete' data-confirm='Delete this entry?' style='color:#c44') ✕

    if content.catsOpenForEntries.length
        .entries-footer: a(href='/home?action=newentry') + New Entry
