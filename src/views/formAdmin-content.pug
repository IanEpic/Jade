//- formAdmin-content.pug
//- Equiv of $form_blank in formAdmin.cgi.

if error === 'noaccess'
    p You do not have permission to access this page.
    p: a(href='/home') Return Home
else
    style.
        .admin-form { width: 100%; max-width: 860px; margin: 0 auto; font-family: inherit; }
        .admin-form fieldset { border: 1px solid #666; border-radius: 4px; margin-bottom: 18px; padding: 12px 18px; }
        .admin-form legend { font-weight: bold; padding: 0 6px; }
        .admin-form table { border-collapse: collapse; width: 100%; }
        .admin-form td { padding: 4px 8px; vertical-align: middle; }
        .admin-form td:first-child { white-space: nowrap; width: 1%; text-align: right; padding-right: 12px; }
        .admin-form .checkbox-table td:first-child { text-align: left; width: 1%; padding-right: 6px; }
        .admin-form .checkbox-table td:nth-child(2) { text-align: left; width: auto; }
        .admin-form input[type=text] { width: 100%; box-sizing: border-box; }
        .admin-form .sub-table td:first-child { padding-left: 16px; }
        .admin-form .note { color: #c80; font-size: 0.85em; padding-left: 10px; }
        .admin-form .rich-label { font-weight: bold; padding-top: 10px; }
        .admin-form textarea { width: 100%; box-sizing: border-box; }
        .admin-form .form-actions { text-align: center; margin-top: 10px; }
        .admin-form .form-actions a, .admin-form .form-actions button { margin: 0 8px; }
        .admin-form .accordion-legend { cursor: pointer; user-select: none; display: flex; align-items: center; gap: 6px; }
        .admin-form .accordion-legend::after { content: ' ▴'; font-size: 11px; color: #aaa; }
        .admin-form .accordion-legend.collapsed::after { content: ' ▾'; }
        .admin-form .accordion-body { display: none; }
        .admin-form .tech-table td:first-child { text-align: left; white-space: nowrap; }

    form.admin-form(method='POST' action='/admin')

        h2(style='text-align:center') Program Control

        //- ── General ──────────────────────────────────────────────────────────
        fieldset
            legend General
            table
                tr
                    td Program Name
                    td: input(type='text' name='name' value=program.name size='50' maxlength='300')

        //- ── Portal Flags ─────────────────────────────────────────────────────
        fieldset
            legend.accordion-legend.collapsed(data-action='toggle-accordion') Portal Flags
            div.accordion-body
                table.checkbox-table
                    tr
                        td: input(type='checkbox' name='portalopen' value='ON' checked=program.portalopen)
                        td: label Portal Open
                    tr
                        td: input(type='checkbox' name='finalistlistavailable' value='ON' checked=program.finalistlistavailable)
                        td: label Finalist List Available
                    tr
                        td: input(type='checkbox' name='finalistscoresavailable' value='ON' checked=program.finalistscoresavailable)
                        td: label Finalist Scores Available
                    tr
                        td: input(type='checkbox' name='nonfinalistscoresavailable' value='ON' checked=program.nonfinalistscoresavailable)
                        td: label Non-Finalist Scores Available
                    tr
                        td: input(type='checkbox' name='feedbackopen' value='ON' checked=program.feedbackopen)
                        td: label Entrant Feedback Open
                    tr
                        td: input(type='checkbox' name='faveventavailable' value='ON' checked=program.faveventavailable)
                        td: label Favourite Event Nominations Open

        //- ── Default Category Settings ────────────────────────────────────────
        fieldset
            legend.accordion-legend.collapsed(data-action='toggle-accordion') Default Category Settings
            div.accordion-body
                table.checkbox-table
                    tr
                        td: input(type='checkbox' name='entriesopen' value='ON' checked=program.entriesopendefault)
                        td: label Entries Open
                        if entryExceptions && entryExceptions.length
                            td.note NOTE: Some categories are not using this default
                    tr
                        td: input(type='checkbox' name='paymentsopen' value='ON' checked=program.paymentsopendefault)
                        td: label Payments Open
                        if paymentExceptions && paymentExceptions.length
                            td.note NOTE: Some users are not using this default
                    tr
                        td: input(type='checkbox' name='judgingopen' value='ON' checked=program.judgingopendefault)
                        td: label Judging Open
                        if judgingExceptions && judgingExceptions.length
                            td.note NOTE: Some categories are not using this default
                    tr
                        td: input(type='checkbox' name='scoreready' value='ON' checked=program.scorereadydefault)
                        td: label Score Ready
                    tr
                        td: input(type='checkbox' name='finalistreview' value='ON' checked=program.finalistreviewdefault)
                        td: label Finalist Review
                    tr
                        td: input(type='checkbox' name='wildcarddecision' value='ON' checked=program.wildcarddecisiondefault)
                        td: label Wildcard Decision
                    tr
                        td: input(type='checkbox' name='winnernomination' value='ON' checked=program.winnernominationdefault)
                        td: label Winner Nomination
                    tr(style='border-top:1px solid #444')
                        td(style='padding-top:8px'): input(type='checkbox' name='overwrite' value='ON')
                        td(style='padding-top:8px'): label Overwrite all records with defaults above

        //- ── Technical ────────────────────────────────────────────────────────
        fieldset
            legend.accordion-legend.collapsed(data-action='toggle-accordion') Technical
            div.accordion-body
                table.tech-table
                    tr
                        td Standard HTML File
                        td: input(type='text' name='standardhtml' value=program.standardhtml || '' size='50' maxlength='200')
                    tr
                        td Email HTML File
                        td: input(type='text' name='emailhtml' value=program.emailhtml || '' size='50' maxlength='200')
                    tr
                        td Login HTML File
                        td: input(type='text' name='loginhtml' value=program.loginhtml || '' size='50' maxlength='200')
                    tr
                        td SMTP Host
                        - let smtpParsed = (() => { try { return JSON.parse(program.smtpserver || '{}'); } catch(e) { return { host: program.smtpserver || '' }; } })()
                        td: input(type='text' name='smtp_host' placeholder='host' value=smtpParsed.host || '' size='50' maxlength='200')
                    tr
                        td SMTP Port
                        td: input(type='number' name='smtp_port' placeholder='25' value=smtpParsed.port || '' size='6' maxlength='5' style='width:80px')
                    tr
                        td Email From Address
                        td: input(type='text' name='emailfromaddress' value=program.emailfromaddress || '' size='50' maxlength='200')
                    tr
                        td Invoice Number Precursor
                        td: input(type='text' name='invoicenoprecursor' value=program.invoicenoprecursor || '' size='5' maxlength='5' style='width:80px')
                    tr
                        td Eway Customer No
                        td: input(type='text' name='ewaycustomerno' value=program.ewaycustomerno || '' size='8' maxlength='8' style='width:120px')
                    tr
                        td Eway Gateway Address
                        td: input(type='text' name='ewaygatewayaddress' value=program.ewaygatewayaddress || '' size='50' maxlength='200')

        //- ── Rich Text Fields ─────────────────────────────────────────────────
        - var richGroups = [{label:'Login & Download',fields:[{label:'Login Page Text',name:'loginpagetext'},{label:'Download Page Content',name:'downloadpagehtml'}]},{label:'Invoicing & Payments',fields:[{label:'Invoice From Text',name:'invoicefromtext'},{label:'Payment Instructions Text',name:'paymentinstructionstext'},{label:'Remittance Advice Text',name:'remittanceadvicetext'},{label:'Receipt Text',name:'receipttext'}]},{label:'Home Page Text',fields:[{label:'Admin Welcome Text',name:'adminwelcometext'},{label:'Judge Welcome Text',name:'judgewelcometext'},{label:'Finalist Welcome Text',name:'finalistwelcometext'},{label:'Non Finalist Welcome Text',name:'nonfinalistwelcometext'},{label:'Standard Welcome Text',name:'standardwelcometext'}]},{label:"T's and C's",fields:[{label:'Entry Terms & Conditions',name:'entrytctext'},{label:'Judge Terms & Conditions',name:'judgetctext'}]},{label:'Help',fields:[{label:'User Help',name:'userhelptext'},{label:'Judge Help',name:'judgehelptext'},{label:'Judge Contacts',name:'judgecontacttext'}]},{label:'Explanations',fields:[{label:'Text Explaining Scores',name:'scoresexplained'},{label:'Text Explaining Entry Costs',name:'costexplanationtext'}]}]
        each group in richGroups
            fieldset
                legend.accordion-legend.collapsed(data-action='toggle-accordion')!= group.label
                div.accordion-body
                    each field in group.fields
                        p.rich-label= field.label
                        textarea.mceEditor(name=field.name rows='5')= program[field.name] || ''

        //- ── Actions ──────────────────────────────────────────────────────────
        .form-actions
            a.btn-secondary(href='/home') Cancel
            button.btn(type='submit' name='submit' value='Save Program') Save Program

    script(src='https://cdn.tiny.cloud/1/t5u2zqqe9s1ltcgp3yrcdormdh3wb2qaquf31suupv3rupdw/tinymce/7/tinymce.min.js' referrerpolicy='origin')
    script(src='/js/form-admin.js')
