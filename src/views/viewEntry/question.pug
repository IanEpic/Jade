//- viewEntry/question.pug
//- Renders one question + its response as a .ve-question block.

- let resp = responses[q.questionid]
- let num  = questionNum
- let noResp = '[No Response Provided]'

if q.inputtype === 'noinput'
    .ve-noinput!= q.questiontext
        if q.description
            br
            i!= q.description

else if q.inputtype === 'textfield'
    .ve-question
        .ve-q-label!= num + '. ' + q.questiontext
        if q.description
            .ve-q-desc!= q.description
        .ve-q-answer
            if resp && resp.value
                = resp.value
            else
                span.ve-q-noresp= noResp

else if q.inputtype === 'drop down list' || q.inputtype === 'radio'
    - let rawVal = resp ? resp.value : null
    - let optById = rawVal && q.inputoptions ? q.inputoptions.find(o => String(o.inputoptionid) === String(rawVal)) : null
    - let optByName = rawVal && q.inputoptions ? q.inputoptions.find(o => o.name === rawVal) : null
    - let resolvedOpt = (optById || optByName)
    - let displayVal = resolvedOpt ? resolvedOpt.name : (rawVal && rawVal !== '--Please Select--' ? rawVal : null)
    .ve-question
        .ve-q-label!= num + '. ' + q.questiontext
        if q.description
            .ve-q-desc!= q.description
        .ve-q-answer
            if displayVal === 'Confirmed' || displayVal === 'Yes'
                span.ve-q-confirmed= displayVal
            else if displayVal
                = displayVal
            else
                span.ve-q-noresp= noResp

else if q.inputtype === 'textarea'
    .ve-question
        .ve-q-label!= num + '. ' + q.questiontext
        if q.description
            .ve-q-desc!= q.description
        .ve-q-answer
            if resp && resp.value
                - let paras = resp.value.split('\n').filter(l => l.trim())
                each para in paras
                    p!= para
            else
                span.ve-q-noresp= noResp

else if q.inputtype === 'checkbox'
    - let selected = resp ? resp.value.split('~') : []
    .ve-question
        .ve-q-label!= num + '. ' + q.questiontext
        if q.description
            .ve-q-desc!= q.description
        if q.inputoptions
            .ve-check-grid
                each opt in q.inputoptions
                    - let isSelected = selected.includes(String(opt.inputoptionid)) || selected.includes(opt.name)
                    span= opt.name
                    span(class=isSelected ? 've-check-yes' : 've-check-no')= isSelected ? 'YES' : 'NO'

else if q.inputtype === 'upload'
    .ve-question
        .ve-q-label!= num + '. ' + q.questiontext
        if q.description
            .ve-q-desc!= q.description
        if !resp || !resp.value
            span.ve-q-noresp [No File Uploaded]
        else if !resp.fileExists
            span.ve-q-noresp [Upload Error]
        else
            - let ext = (resp.value || '').split('.').pop().toLowerCase()
            - let isImg = ['jpg','jpeg','png','gif'].includes(ext)
            if isImg
                .ve-media
                    img(src='/' + slug + '/formResponses/image?responseid=' + resp.responseid style='max-width:600px;')
            else
                - let docExt = ext.toUpperCase()
                - let docColour = ({PDF:'#e74c3c',DOC:'#2980b9',DOCX:'#2980b9',XLS:'#27ae60',XLSX:'#27ae60',PPT:'#e67e22',PPTX:'#e67e22'})[docExt] || '#7f8c8d'
                .ve-media(style='text-align:left;')
                    p(style='margin:0 0 8px; font-size:13px; color:#aaa;') Click the link below to open the supporting document.
                    a.ve-doc-link(href='/' + slug + '/formResponses/download?responseid=' + resp.responseid target='_blank')
                        span(style='background:' + docColour + '; color:#fff; font-size:11px; font-weight:bold; padding:3px 7px; border-radius:3px;')= docExt
                        span(style='font-size:22px;') 📄
                        span= resp.originalname || resp.value

else if q.inputtype === 'image'
    .ve-question
        .ve-q-label!= num + '. ' + q.questiontext
        if q.description
            .ve-q-desc!= q.description
        if !resp || !resp.value
            span.ve-q-noresp [No Image Uploaded]
        else if !resp.fileExists
            span.ve-q-noresp [Upload Error]
        else
            .ve-media
                img(src='/' + slug + '/formResponses/image?responseid=' + resp.responseid style='max-width:600px;')
                if resp.caption
                    p.caption= resp.caption

else if q.inputtype === 'video'
    .ve-question
        .ve-q-label!= num + '. ' + q.questiontext
        if q.description
            .ve-q-desc!= q.description
        if !resp || !resp.value
            span.ve-q-noresp [No Video Uploaded]
        else if !resp.fileExists
            span.ve-q-noresp [Upload Error]
        else
            .ve-media
                video(controls style='max-width:100%; max-height:360px;')
                    source(src='/' + slug + '/formResponses/video?responseid=' + resp.responseid type='video/mp4')
                if resp.caption
                    p.caption= resp.caption
