extends ../layout

block content
    if mode === 'new'
        h1 Start a New Entry
        p Step 3 — set up your entry below and then proceed to the questions.
    else
        h2 Edit Entry ##{entry.entryid}

    //- Validation errors — replaces $no_entrant_warning, $no_address_warning etc.
    if errors && errors.length
        .alert.alert-error
            each error in errors
                p= error

    form(name='entryform' method='POST' action=mode === 'new' ? '/entry' : `/entry/${entry.entryid}`)

        input(type='hidden' name='categoryid' value=category.categoryid)
        if mode === 'edit'
            input(type='hidden' name='entryid' value=entry.entryid)

        table(style='width:780px; text-align:left')

            //- Category name + description
            tr
                td: strong Category
                td= category.name
            tr
                td(valign='top'): strong Description
                td= category.description
            tr
                td(colspan='2'): hr

            //- Eligibility rules — replaces $geteligibilitytable
            if category.categoryeligibilitylinks && category.categoryeligibilitylinks.length
                tr
                    td(colspan='2')
                        strong Eligibility
                        br
                        br
                        | Entries in this category must adhere to the following rules:
                tr
                    td(colspan='2')
                        ul
                            each link in category.categoryeligibilitylinks
                                li= link.eligibilityid.eligibilityrule
                tr
                    td(colspan='2'): hr

            //- Criteria — replaces $getcriteriatable
            if category.criteria && category.criteria.length
                tr
                    td(colspan='2')
                        strong Criteria
                        br
                        br
                        | Entries will be assessed according to the following criteria:
                tr
                    td(colspan='2')
                        table
                            tr
                                th Criterion
                                th Weight
                            each c in category.criteria
                                tr
                                    td= c.description
                                    td(align='center') #{c.weight}%
                tr
                    td(colspan='2'): hr

            //- User reference
            tr
                td(colspan='2')
                    strong Your Reference
                    br
                    br
                    | Enter a word or number to distinguish this entry from any others you might have.
            tr
                td
                td
                    input(
                        type='text'
                        name='userref'
                        size='50'
                        maxlength='50'
                        value=mode === 'edit' ? entry.userref : ''
                    )
            tr
                td(colspan='2'): hr

            //- Entrant selector — replaces $entrant_row / $entrant_popup
            if entrants && entrants.length
                tr
                    td: strong Select an Entrant
                    td
                        select(name='entrantid' onchange='checkEntrant(document.entryform)')
                            if mode === 'new'
                                option(value='a') ------ Please Select ------
                                option(value='b') New Entrant Below
                            each entrant in entrants
                                option(
                                    value=entrant.entrantid
                                    selected=mode === 'edit' && entry.entrantid == entrant.entrantid
                                )= entrant.name

            //- New entrant form — replaces $entrant_table
            tr
                td(valign='top')
                    if entrants && entrants.length
                        strong or create a new Entrant
                    else
                        strong Create a new Entrant
                td
                    include ../partials/entrant_fields

            tr
                td(colspan='2'): hr

            //- Submit buttons
            tr
                td(colspan='2' align='center')
                    a.btn.btn-cancel(href='/') Cancel
                    button(type='submit' name='submit' value='home') Save &amp; Return Home
                    button(type='submit' name='submit' value='questions') Save &amp; Proceed to Category Questions
