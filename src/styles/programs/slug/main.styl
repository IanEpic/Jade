// ── Variables ─────────────────────────────────────────────────────────────────
font-stack       = 'Avalon', sans-serif
font-size-base   = 15px
line-height-base = 1.44

color-text       = #fff
color-link       = #baab85
color-gold       = #cf9702
color-gold-dark  = #c48f06
color-gold-nav   = #ffba01
color-black      = #000

transition-base  = all 0.3s ease-in-out

// ── Mixins ────────────────────────────────────────────────────────────────────
transition(args = transition-base)
  transition args

// ── Base ──────────────────────────────────────────────────────────────────────
body
  font-family font-stack
  font-weight 400
  line-height line-height-base
  color color-text
  text-rendering optimizeLegibility
  vertical-align baseline
  font-size font-size-base
  background-size cover
  background-position center center
  background-repeat repeat-y
  background-image url('/img/background-eventawards2018.jpg')
  position relative
  padding-bottom 74px

a
  text-decoration none
  color color-link
  transition()

  &:hover, &:focus
    color color-gold
    outline none

// ── Headings ──────────────────────────────────────────────────────────────────
h1, h2, h3, h4, h5, h6
  clear both
  margin-top 0
  margin-bottom 15px
  padding 0
  font-family font-stack
  font-weight 400
  color color-gold-dark

h1
  font-size 20px

h2
  font-size 18px

h3
  font-size font-size-base
  margin-bottom 0

h4
  font-size 12px

// ── Tables ────────────────────────────────────────────────────────────────────
table
  margin 10px auto

// ── Buttons ───────────────────────────────────────────────────────────────────
btn-base()
  border 0
  border-radius 0
  background #fff
  font-size font-size-base
  color color-black
  padding 3px
  text-transform none
  line-height 1
  display inline-block
  clear both
  text-align center
  margin-right 5px
  transition()

btn-active()
  background color-gold
  color #fff

.btn,
button,
input[type="button"],
input[type="reset"],
input[type="submit"]
  btn-base()

  &:hover, &:focus, &:active
    btn-active()

// ── Form inputs ───────────────────────────────────────────────────────────────
input-types = text email url password search number tel range date month week time datetime datetime-local color

form-input()
  background color-black
  color color-text
  border 1px solid #fff
  border-radius 0
  padding 8px 12px 9px
  font-family font-stack
  font-size font-size-base
  font-weight 400
  transition()

  &:focus
    border-color color-gold

for type in input-types
  input[type={type}]
    form-input()

// confirm_email is a custom type used in the Perl forms
input[type="confirm_email"]
  form-input()

textarea
  form-input()
  width 100%

select
  form-input()
  border 1px solid #fff

  option
    background color-black
    color color-text
    border 1px solid #fff

// ── Layout ────────────────────────────────────────────────────────────────────
#header
  height 98px
  background-color color-black

#decoration
  background-size cover
  background-position center center
  background-repeat no-repeat
  height 206px
  width 100%
  display block
  background-image url('/img/login-header.jpg')

#footer
  font-size 70%
  text-align center
  width 100%
  position fixed
  bottom 0
  left 0
  right 0
  background-color color-black
  padding 15px 0 0 0
  z-index 2

#cgiContent
  text-align center

  // ── Horizontal nav bar ───────────────────────────────────────────────────
  ul#vertnav
    list-style none
    margin 0
    padding 0
    border none
    float left

    li
      float left

    a
      font-size 17px
      color #fff
      width 128px
      text-align center
      float left
      padding 7px 0
      border none

      &:hover
        color color-gold-nav

  // ── Vertical nav bar ─────────────────────────────────────────────────────
  ul#vertnav2
    margin 0
    padding 0 5px 0 10px
    list-style none
    border-right solid 1px #fff

    li
      margin 0
      padding 0

      a
        font-size 17px
        color #fff
        display block
        padding 7px 0 7px 5px
        border none

        &:hover
          color color-gold-nav

// ── Response form ─────────────────────────────────────────────────────────────
#container-progress
  display none

#bar-progress
  display none
  background-color color-gold-dark
  text-align center
  height 1.5em

#container-home
  display none

// ── Alerts (new — used by login/entry error messages) ─────────────────────────
.alert
  padding 10px 15px
  margin-bottom 15px
  border-radius 0

  &.alert-error
    background color-gold-dark
    color #fff
    border-left 4px solid color-gold

  &.alert-info
    background rgba(255, 255, 255, 0.1)
    color color-text
    border-left 4px solid color-link
