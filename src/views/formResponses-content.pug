//- formResponses-content.pug

style.
    .resp-wrap { max-width: 760px; margin: 0 auto; }
    .resp-wrap h2 { color: var(--color-accent-strong); margin-bottom: 4px; text-align: center; }
    .resp-wrap .entry-meta { color: var(--text-arrow); font-size: 13px; margin-bottom: 16px; text-align: center; }
    .resp-wrap .question-block { border-top: 1px solid var(--border-faint); padding: 14px 0; text-align: left; }
    .resp-wrap .question-label { font-weight: bold; margin-bottom: 6px; text-align: left; }
    .resp-wrap .dd-row { display: flex; align-items: center; gap: 12px; }
    .resp-wrap .dd-row .question-label { margin-bottom: 0; flex: 1; }
    .resp-wrap .dd-row select { flex-shrink: 0; }
    .resp-wrap .dd-row + .question-desc { margin-top: 8px; }
    .resp-wrap .question-desc { font-size: 12px; color: var(--text-arrow); font-style: italic; margin-bottom: 8px; text-align: left; }
    .resp-wrap .word-limit { font-size: 12px; color: var(--color-accent-strong); margin-bottom: 6px; }
    .resp-wrap .noinput-block { border-top: 1px solid var(--border-faint); padding: 14px 0; text-align: center; }
    .resp-wrap input[type=text], .resp-wrap textarea, .resp-wrap select { background: var(--surface-deep); color: var(--color-text); border: 1px solid var(--border); padding: 6px 10px; font-family: inherit; font-size: 14px; box-sizing: border-box; }
    .resp-wrap input[type=text]:focus, .resp-wrap textarea:focus, .resp-wrap select:focus { border-color: var(--color-accent-strong); outline: none; }
    .resp-wrap textarea { width: 100%; resize: vertical; }
    .resp-wrap .word-count { font-size: 12px; color: var(--text-arrow); margin-top: 4px; }
    .resp-wrap .word-count input { width: 50px; text-align: center; padding: 2px 4px; }
    .resp-wrap .checkbox-group, .resp-wrap .radio-group { display: grid; grid-template-columns: repeat(3,1fr); gap: 4px 12px; margin-top: 6px; }
    .resp-wrap .checkbox-group label, .resp-wrap .radio-group label { display: flex; align-items: center; gap: 6px; font-size: 13px; }
    .resp-wrap .file-current { font-size: 13px; margin-bottom: 8px; color: var(--text-arrow); display: flex; gap: 16px; align-items: center; flex-wrap: wrap; }
    .resp-wrap .file-current a { color: var(--color-accent-strong); }
    .resp-wrap .btn-dz-remove { margin-left: 10px; background: transparent; color: #c44; border: 1px solid #c44; border-radius: 3px; padding: 2px 8px; font-size: 11px; cursor: pointer; margin-top: 6px; display: inline-block; }
    .resp-wrap .btn-dz-remove:hover { background: #c44; color: #fff; }
    .resp-wrap .dz-stop-btn { display: none; margin-top: 6px; background: transparent; color: var(--text-dim); border: 1px solid var(--border); border-radius: 3px; padding: 2px 10px; font-size: 11px; cursor: pointer; }
    .resp-wrap .dz-stop-btn:hover { border-color: #c44; color: #c44; }
    .resp-wrap .dropzone { border: 2px dashed #555; border-radius: 6px; padding: 20px; text-align: center; cursor: pointer; transition: all 0.2s; position: relative; margin-top: 6px; }
    .resp-wrap .dropzone:hover, .resp-wrap .dropzone.drag-over { border-color: var(--color-accent-strong); background: rgba(196,143,6,0.06); }
    .resp-wrap .dropzone.uploaded { border-color: #4caf50; border-style: solid; }
    .resp-wrap .dz-icon { font-size: 28px; margin-bottom: 6px; }
    .resp-wrap .dz-text { color: var(--text-arrow); font-size: 13px; }
    .resp-wrap .dz-input { position: absolute; width: 0; height: 0; opacity: 0; overflow: hidden; pointer-events: none; }
    .resp-wrap .dz-bar { height: 6px; background: var(--border-subtle); border-radius: 3px; margin-top: 10px; overflow: hidden; }
    .resp-wrap .dz-bar-fill { height: 100%; background: var(--color-accent-strong); width: 0; transition: width 0.2s; }
    .resp-wrap .dz-preview { margin-top: 8px; }
    .resp-wrap .dz-preview .dz-thumb { display: block; max-height: 120px; max-width: 240px; width: auto; height: auto; border: 1px solid var(--border-subtle); object-fit: contain; }
    .resp-wrap .dz-uploading { display: none; width: 120px; height: 80px; background: var(--surface); border: 1px solid var(--border-subtle); border-radius: 4px; align-items: center; justify-content: center; flex-direction: column; gap: 8px; color: var(--text-arrow); font-size: 12px; }
    .resp-wrap .dz-uploading.active { display: flex; }
    @keyframes dz-pulse { 0%,100% { opacity: 0.3; } 50% { opacity: 1; } }
    .resp-wrap .dz-uploading-icon { font-size: 24px; animation: dz-pulse 1.2s ease-in-out infinite; }
    .resp-wrap .dz-filename { font-size: 12px; color: #4caf50; }
    .resp-wrap .dz-file-icon { display: inline-block; color: var(--color-text); font-size: 11px; font-weight: bold; padding: 3px 6px; border-radius: 3px; margin-right: 6px; vertical-align: middle; letter-spacing: 0.5px; }
    .resp-wrap .dz-err { color: #c44; font-size: 12px; margin-top: 6px; }
    .resp-wrap .progress-bar { display: none; height: 8px; background: var(--border-subtle); border-radius: 4px; margin-top: 12px; overflow: hidden; }
    .resp-wrap .progress-bar-fill { height: 100%; background: var(--color-accent-strong); width: 0; transition: width 0.3s; }
    .resp-wrap .save-status { text-align: center; font-size: 13px; margin-top: 8px; min-height: 20px; }
    .resp-wrap .btn-undo { background: transparent; color: var(--color-accent-strong); border: 1px solid var(--color-accent-strong); border-radius: 3px; padding: 1px 6px; font-size: 11px; cursor: pointer; margin-left: 6px; vertical-align: middle; }
    .resp-wrap .btn-undo:hover { background: var(--color-accent-strong); color: #000; }
    .resp-wrap .form-actions { display: flex; justify-content: center; gap: 12px; margin-top: 20px; padding-top: 16px; border-top: 1px solid var(--border-subtle); align-items: center; }
    .resp-wrap .form-actions .btn { text-decoration: none; }
    .resp-wrap .closed-msg { text-align: center; color: var(--text-arrow); padding: 20px; }

.resp-wrap

    if closed
        .closed-msg
            p Entries are currently closed for this category.
            a.btn-secondary(href='/home') Home

    else
        h2= entry.categoryname
        p.entry-meta Entry ##{entry.entryid} &nbsp;·&nbsp; #{entry.entrantname || ''}

        //- Criteria box
        if questions.some && questions.some(q => q.inputtype !== 'noinput')
            //- (criteria shown on formEntry page already)

        form#response-form(method='POST' action='/formResponses' enctype='multipart/form-data')
            input(type='hidden' name='entryid' value=entry.entryid)

            - let questionNum = 0
            each q in questions
                - const resp = responses[q.questionid]
                - const respid = resp ? resp.responseid : ''
                - const respval = resp ? (resp.value || '') : ''
                - const fieldbase = 'HHH' + q.questionid + 'HHH' + respid + 'HHH'
                - if (q.inputtype !== 'noinput') questionNum++
                - const num = questionNum

                if q.inputtype === 'noinput'
                    .noinput-block!= q.questiontext
                else
                    .question-block
                        if q.inputtype === 'drop down list'
                            .dd-row
                                .question-label!= num + '. ' + q.questiontext
                                - const ddopts2 = q.options || []
                                select(name=fieldbase+'dd')
                                    option(value='') -- Select --
                                    each opt in ddopts2.filter(o => !/^[-\s]*(select|please select)[-\s]*$/i.test(o.name))
                                        option(value=opt.inputoptionid selected=(respval == opt.inputoptionid))= opt.name
                            if q.description
                                .question-desc!= q.description
                        else
                            .question-label!= num + '. ' + q.questiontext
                            if q.description
                                .question-desc!= q.description
                        if q.inputtype === 'textfield'
                            - const tfWidth = q.inputwidth ? q.inputwidth + 'ch' : '600px'
                            input(type='text' name=fieldbase+'tf' value=respval style=('width:' + tfWidth))
                            button.btn-undo(type='button' style='display:none' data-action='undo') ↩ Undo
                        else if q.inputtype === 'textarea'
                            if q.maxsize
                                .word-limit Word limit: #{q.maxsize} words
                            - const taname = fieldbase + 'ta'
                            textarea(name=taname rows=q.inputheight||6 style='width:100%' data-wordlimit=(q.maxsize || 0))= respval
                            .word-count
                                if q.maxsize
                                    | Word count:&nbsp;
                                    input(type='text' name=taname+'c' value=countContentWords(respval) readonly)
                                    | &nbsp;
                                    span.word-over(data-over=taname style='color:#c44; font-weight:600; display:none')
                                button.btn-undo(type='button' style='display:none' data-action='undo') ↩ Undo
                        else if q.inputtype === 'checkbox'
                            - const cbopts = q.options || []
                            - const cbvals = respval ? respval.split('~') : []
                            input(type='hidden' name=fieldbase+'cb' value='cb')
                            .checkbox-group
                                each opt in cbopts
                                    label
                                        input(type='checkbox' name=fieldbase+'cb' value=opt.inputoptionid checked=cbvals.includes(String(opt.inputoptionid)))
                                        = opt.name
                        else if q.inputtype === 'radio'
                            - const raopts = q.options || []
                            .radio-group
                                each opt in raopts
                                    label
                                        input(type='radio' name=fieldbase+'ra' value=opt.inputoptionid checked=(respval == opt.inputoptionid))
                                        = opt.name
                        else if q.inputtype === 'upload'
                            - const ulHidden = fieldbase + 'ul'
                            input(type='hidden' name=ulHidden value=respval)
                            .dropzone(data-field=ulHidden data-type='file' data-responseid=(resp ? resp.responseid : '') data-entryid=entry.entryid data-qid=q.questionid class=(respval ? 'uploaded' : ''))
                                .dz-icon 📄
                                .dz-text= respval ? 'Click or drop to replace' : 'Drop a file here or click to browse'
                                input(type='file' class='dz-input')
                                .dz-preview(style=(respval ? 'display:block' : 'display:none'))
                                    if resp && respval
                                        - const displayName = resp.originalname || respval
                                        - const ext = (displayName.split('.').pop() || '').toLowerCase()
                                        - const iconColors = {pdf:'#e74c3c',doc:'#2980b9',docx:'#2980b9',xls:'#27ae60',xlsx:'#27ae60',ppt:'#e67e22',pptx:'#e67e22',zip:'#8e44ad',rar:'#8e44ad','7z':'#8e44ad',csv:'#16a085',txt:'#7f8c8d'}
                                        - const iconColor = iconColors[ext] || 'var(--border)'
                                        - const iconLabel = ext ? ext.toUpperCase() : 'FILE'
                                        a.dz-filename(href='/'+slug+'/formResponses/download?responseid='+resp.responseid target='_blank')
                                            span.dz-file-icon(style='background:'+iconColor)= iconLabel
                                            = displayName
                                    else
                                        span.dz-filename
                                    button.btn-dz-remove(type='button' data-action='remove-file') ✕ Remove
                                .dz-bar(style='display:none'): .dz-bar-fill
                                button.dz-stop-btn(type='button' data-action='stop-upload') ✕ Stop upload
                                .dz-err(style='display:none')
                        else if q.inputtype === 'image'
                            - const imHidden = fieldbase + 'im'
                            input(type='hidden' name=imHidden value=respval)
                            .dropzone(data-field=imHidden data-type='image' data-responseid=(resp ? resp.responseid : '') data-entryid=entry.entryid data-qid=q.questionid class=(respval ? 'uploaded' : ''))
                                .dz-icon 🖼
                                .dz-text= respval ? 'Click or drop to replace' : 'Drop an image here or click to browse'
                                input(type='file' class='dz-input' accept='image/*')
                                .dz-preview(style=(respval ? 'display:block' : 'display:none'))
                                    .dz-uploading
                                        span.dz-uploading-icon 🖼
                                        span Uploading…
                                    if resp && respval
                                        img.dz-thumb(src='/'+slug+'/formResponses/image?responseid='+resp.responseid)
                                    else
                                        img.dz-thumb
                                    button.btn-dz-remove(type='button' data-action='remove-file') ✕ Remove
                                .dz-bar(style='display:none'): .dz-bar-fill
                                button.dz-stop-btn(type='button' data-action='stop-upload') ✕ Stop upload
                                .dz-err(style='display:none')
                            if q.captionlabel
                                .question-desc(style='margin-top:10px')!= q.captionlabel
                                textarea(name='CAP'+q.questionid rows='3' style='width:100%')= resp && resp.caption ? resp.caption : ''
                        else if q.inputtype === 'video'
                            - const vidHidden = fieldbase + 'vid'
                            input(type='hidden' name=vidHidden value=respval)
                            .dropzone(data-field=vidHidden data-type='video' data-responseid=(resp ? resp.responseid : '') data-entryid=entry.entryid data-qid=q.questionid class=(respval ? 'uploaded' : ''))
                                .dz-icon 🎬
                                .dz-text= respval ? 'Click or drop to replace' : 'Drop a video here or click to browse'
                                input(type='file' class='dz-input' accept='video/*')
                                .dz-preview(style=(respval ? 'display:block' : 'display:none'))
                                    if resp && respval
                                        video.dz-video-player(src='/'+slug+'/formResponses/video?responseid='+resp.responseid controls preload='metadata' style='max-width:100%;max-height:200px;display:block;margin-bottom:4px;')
                                    else
                                        video.dz-video-player(controls preload='metadata' style='max-width:100%;max-height:200px;display:none;margin-bottom:4px;')
                                    button.btn-dz-remove(type='button' data-action='remove-file') ✕ Remove
                                .dz-bar(style='display:none'): .dz-bar-fill
                                button.dz-stop-btn(type='button' data-action='stop-upload') ✕ Stop upload
                                .dz-err(style='display:none')
                            if q.captionlabel
                                .question-desc(style='margin-top:10px')!= q.captionlabel
                                textarea(name='CAP'+q.questionid rows='3' style='width:100%')= resp && resp.caption ? resp.caption : ''

            p.save-status#save-status

            #upload-progress(style='display:none; background:var(--surface); border:1px solid var(--color-accent-strong); border-radius:4px; padding:10px 14px; margin-bottom:12px;')
                p(style='color:var(--color-accent-strong); font-size:13px; text-align:center; margin:0 0 7px;') ⏳ Upload in progress — please wait before navigating away…
                div(style='height:8px; background:var(--border-subtle); border-radius:4px; overflow:hidden;')
                    #upload-progress-fill(style='height:100%; background:var(--color-accent-strong); width:0; transition:width 0.25s ease;')
                p#upload-progress-label(style='text-align:center; font-size:11px; color:var(--text-arrow); margin:5px 0 0;') 0%

            .form-actions
                a.btn-secondary(href='/home') Home
                button.btn(type='button' id='btn-save' data-action='save') Save
                a.btn(href='/viewEntry?entryid=' + entry.entryid id='btn-review') Review &amp; Finalise

script(src='/js/form-responses.js?v=' + buildHash)
