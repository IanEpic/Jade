//- home/activeusers.pug

style.
    .rpt-wrap { max-width: 960px; margin: 0 auto; }
    .rpt-wrap h3 { color: #c48f06; font-size: 18px; text-align: center; margin-bottom: 6px; }
    .rpt-wrap .rpt-desc { color: #aaa; font-size: 13px; text-align: center; margin-bottom: 16px; }
    .rpt-table { width: 100%; border-collapse: collapse; font-size: 13px; }
    .rpt-table th { font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; border-bottom: 1px solid #555; padding: 6px 8px; text-align: left; color: #c48f06; white-space: nowrap; }
    .rpt-table th.num { text-align: right; }
    .rpt-table td { padding: 6px 8px; border-bottom: 1px solid #2a2a2a; vertical-align: middle; }
    .rpt-table td.num { text-align: right; color: #ccc; }
    .rpt-table tr:hover td { background: rgba(255,255,255,0.04); }
    .rpt-actions { text-align: center; margin-top: 20px; }

.rpt-wrap
    h3 Active Users
    p.rpt-desc All non-excluded users for this program, with last logon and entry counts.

    if content.rows && content.rows.length
        table.rpt-table
            thead
                tr
                    th Email
                    th First Name
                    th Last Name
                    th Organisation
                    th Last Logon
                    th.num Started
                    th.num Paid
                    th.num Finalised
            tbody
                each r in content.rows
                    tr
                        td= r.email || ''
                        td= r.firstname || ''
                        td= r.lastname || ''
                        td= r.organisation || ''
                        td= r.LastLogon ? new Date(r.LastLogon).toLocaleDateString('en-AU') : '—'
                        td.num= r.started
                        td.num= r.paid
                        td.num= r.finalised
    else
        p(style='color:#888; text-align:center; margin-top:24px;') No users found.

    .rpt-actions
        a.btn(href='/' + program.slug + '/reportActiveUsers') ⬇ Download Excel
