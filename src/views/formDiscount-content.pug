style.
    .disc-wrap { max-width: 900px; margin: 0 auto; }
    .disc-wrap h3 { color: #c48f06; font-size: 18px; text-align: center; margin-bottom: 16px; }
    .disc-table { border-collapse: collapse; width: 100%; }
    .disc-table th { font-size: 11px; text-transform: uppercase; color: #c48f06; border-bottom: 1px solid #555; padding: 4px 8px; text-align: left; white-space: nowrap; }
    .disc-table td { padding: 5px 8px; border-bottom: 1px solid #1e1e1e; vertical-align: middle; font-size: 11px; color: #fff; }
    .disc-table .disc-actions a { margin-right: 10px; font-size: 12px; }
    .disc-table tr.hidden { display: none; }
    .disc-toolbar { display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px; }
    #disc-search { flex: 1; max-width: 320px; padding: 6px 10px; background: #111; color: #fff; border: 1px solid #555; font-size: 14px; }
    #disc-search:focus { border-color: #c48f06; outline: none; }
    .badge { display: inline-block; padding: 2px 7px; border-radius: 3px; font-size: 10px; font-weight: 600; }
    .badge-eb   { background: #1a4a1a; color: #4caf50; }
    .badge-code { background: #1a2a4a; color: #64b5f6; }
    .badge-off  { background: #3a2a00; color: #888; }
    .disc-form-wrap { display: none; background: #111; border: 1px solid #555; border-radius: 4px; padding: 16px 18px; margin-bottom: 16px; }
    .disc-form-wrap h4 { color: #c48f06; margin: 0 0 12px; font-size: 15px; }
    .disc-form fieldset { border: 1px solid #555; border-radius: 4px; padding: 14px 18px; margin-bottom: 16px; }
    .disc-form legend { font-weight: bold; padding: 0 6px; color: #c48f06; }
    .disc-form table { border-collapse: collapse; width: 100%; }
    .disc-form td { padding: 5px 8px; vertical-align: middle; }
    .disc-form td:first-child { text-align: right; width: 130px; padding-right: 10px; white-space: nowrap; }
    .disc-form input[type=text], .disc-form input[type=number], .disc-form input[type=date], .disc-form select { background: #1a1a1a; color: #eee; border: 1px solid #555; padding: 5px 8px; border-radius: 3px; font-size: 13px; }
    .disc-form input[type=date]::-webkit-calendar-picker-indicator { filter: invert(1); }
    .disc-form input[type=text] { width: 220px; }
    .disc-form .form-actions { margin-top: 12px; display: flex; gap: 10px; align-items: center; }
    .alert-ok  { background: #1a4a1a; color: #fff; padding: 8px 12px; border-left: 4px solid #4caf50; margin-bottom: 14px; }
    .alert-err { background: #7a2a00; color: #fff; padding: 8px 12px; border-left: 4px solid #c44; margin-bottom: 14px; }
    #code-row { display: none; }

.disc-wrap

    h3 Manage Discounts

    if success
        p.alert-ok Discount saved.
    if error
        p.alert-err= error

    //- â”€â”€ Inline add/edit form â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
    div.disc-form-wrap#disc-form-wrap
        h4#disc-form-title Add Discount
        form.disc-form(method='POST' action='/formDiscount' id='discount-form')
            input#disc-id-field(type='hidden' name='discountid' value='')
            fieldset
                legend Discount Details
                table
                    tr
                        td Name
                        td: input(type='text' name='name' value='' maxlength='100' placeholder='e.g. Early Starters Discount' style='width:300px')
                    tr
                        td Type
                        td
                            select(name='type')
                                option(value='earlybird') Early Bird
                                option(value='code') Promo Code
                    tr#code-row
                        td Code
                        td: input(type='text' name='code' value='' maxlength='50' placeholder='e.g. SAVE20')
                    tr
                        td Amount
                        td
                            input(type='number' name='amount' value='' min='0' step='0.01' style='width:100px')
                            |  &nbsp;
                            select(name='amounttype')
                                option(value='dollars') $ per entry (inc GST)
                                option(value='percent') % of total
                    tr
                        td Valid From
                        td: input(type='date' name='validfrom' value='')
                    tr
                        td Valid To
                        td: input(type='date' name='validto' value='')
                    tr
                        td Max Uses
                        td: input(type='number' name='maxuses' value='' min='1' placeholder='Unlimited' style='width:100px')
                    tr
                        td Active
                        td
                            select(name='active')
                                option(value='1') Yes
                                option(value='0') No
            .form-actions
                a.btn-secondary(href='#' id='disc-cancel') Cancel
                button#disc-submit-btn.btn(type='submit') Add Discount

    //- â”€â”€ Toolbar â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
    .disc-toolbar
        input#disc-search(type='text' placeholder='Search discountsâ€¦' data-filter='.disc-table tbody tr')
        a(href='#' id='btn-new-disc') + New Discount

    //- â”€â”€ List â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
    if discounts.length
        table.disc-table
            thead
                tr
                    th Name
                    th Type
                    th Code
                    th Discount
                    th Valid From
                    th Valid To
                    th Uses
                    th Status
                    th
            tbody
                each d in discounts
                    tr
                        td= d.name || 'â€”'
                        td: span.badge(class=d.type === 'earlybird' ? 'badge-eb' : 'badge-code')= d.type === 'earlybird' ? 'Early Bird' : 'Code'
                        td= d.code || 'â€”'
                        td= d.amounttype === 'percent' ? d.amount + '%' : '$' + parseFloat(d.amount).toFixed(2) + ' per entry'
                        td= d.validfrom ? new Date(d.validfrom).toLocaleDateString('en-AU') : 'â€”'
                        td= d.validto   ? new Date(d.validto).toLocaleDateString('en-AU')   : 'â€”'
                        td= d.usecount + (d.maxuses ? ' / ' + d.maxuses : '')
                        td: span.badge(class=d.active ? '' : 'badge-off')= d.active ? 'Active' : 'Inactive'
                        td.disc-actions(style='white-space:nowrap')
                            a(href='/home?action=discounts&discountid=' + d.discountid title='Edit') âœï¸
                            a(href='/home?action=discounts&delete=' + d.discountid data-confirm='Delete this discount?' title='Delete' style='color:#c44') âœ•
    else
        p(style='color:#888; font-size:13px') No discounts configured.

script(src='/js/jade.js?v=' + buildHash)
script(src='/js/home-discount.js?v=' + buildHash)
