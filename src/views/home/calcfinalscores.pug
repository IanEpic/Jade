-
    var slug        = program.slug
    var baseUrl     = '/' + slug + '/home?action=calcfinalscores'
    var ignoreReady = content.ignoreReady
    var topN        = content.topN
    var minRawScore = content.minRawScore
    var ignoreQs    = (ignoreReady ? '&ignoreScoreReady=1' : '') + '&topN=' + topN + '&minRawScore=' + minRawScore
    var categories  = content.categories

style.
    .cfs-wrap { max-width: 900px; margin: 0 auto; }
    .cfs-wrap h2 { text-align: center; color: var(--color-accent-strong); margin-bottom: 20px; }
    .cfs-options { display: flex; align-items: center; gap: 24px; margin-bottom: 20px; flex-wrap: wrap; padding: 10px 14px; background: var(--surface); border: 1px solid var(--border-dashed); border-radius: 4px; }
    .cfs-options label { display: flex; align-items: center; gap: 6px; font-size: 13px; color: var(--text-label); }
    .cfs-options input[type=number] { width: 64px; background: var(--surface-deep); color: var(--color-text); border: 1px solid var(--border); border-radius: 4px; padding: 4px 8px; font-size: 13px; }
    .cfs-options input[type=number]:focus { border-color: var(--color-accent-strong); outline: none; }
    .cfs-card { border: 1px solid var(--border-dashed); border-radius: 4px; margin-bottom: 14px; overflow: hidden; }
    .cfs-card-header { background: var(--surface-1); padding: 8px 14px; display: flex; align-items: center; justify-content: space-between; }
    .cfs-card-header .cat-name { font-size: 13px; font-weight: 600; color: var(--color-accent-strong); }
    .cfs-card-header .cat-meta { font-size: 11px; color: var(--text-dim); }
    .cfs-card table { width: 100%; border-collapse: collapse; table-layout: fixed; }
    .cfs-card th { font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; color: var(--color-accent-strong); padding: 5px 10px; border-bottom: 1px solid var(--border-subtle); text-align: left; }
    .cfs-card td { padding: 6px 10px; font-size: 13px; border-bottom: 1px solid var(--surface-2); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .cfs-card tr:last-child td { border-bottom: none; }
    .cfs-card tr.below-min td { opacity: 0.45; }
    .cfs-card .r { text-align: right; }
    .cfs-card .c { text-align: center; }
    .finalist-badge { display: inline-block; font-size: 11px; padding: 1px 7px; border-radius: 2px; font-weight: 600; background: #1a3a4a; color: #64b5f6; }
    .below-min-label { font-size: 11px; color: var(--border-mid); }
    .raw-fail { color: #f88; }
    .form-actions { margin-top: 20px; display: flex; gap: 8px; align-items: center; justify-content: center; }

.cfs-wrap
    h2 Calculate Final Scores

    if content.locked
        div(style='background:#2a2200; border-left:4px solid var(--color-accent-strong); color:#f0d9a8; padding:12px 16px; font-size:13px; line-height:1.6;')
            strong Score calculation is locked for this program.
            br
            | This program&rsquo;s results are final, so Calculate Final Scores is disabled to protect the published scores, finalist flags and per-criteria breakdown from accidental changes. If a recalculation is genuinely required, an administrator can clear the program&rsquo;s &ldquo;lock scores&rdquo; flag first.
        .form-actions(style='margin-top:20px; text-align:center;')
            a.btn-secondary(href='/' + slug + '/home?action=program') Back
    else
        if content.wrote
            div(style='background:var(--ok-bg); border-left:4px solid #4c4; color:#cfc; padding:10px 14px; font-size:13px; margin-bottom:16px;')
                | Final scores written to database (#{content.rowCount} entries across #{content.categoryCount} categories). Top #{topN} per category flagged as finalists.

        .cfs-options
            label
                input(type='checkbox' id='ignoreReadyInput' checked=ignoreReady)
                |  Include non-score-ready categories
            label
                | Top
                input(type='number' id='topNInput' min='1' max='99' value=topN)
                | finalists per category
            label
                | Min raw score
                input(type='number' id='minRawInput' min='0' max='10' step='0.01' value=minRawScore)

        if !categories || !categories.length
            p(style='color:var(--text-arrow);') No scored entries found for this program#{ ignoreReady ? '' : ' with Score Ready categories' }.

        else
            each cat in categories
                .cfs-card
                    .cfs-card-header
                        span.cat-name= cat.categoryname
                        span.cat-meta #{cat.entries.filter(function(e){return e.finalist}).length} finalist#{cat.entries.filter(function(e){return e.finalist}).length !== 1 ? 's' : ''} of #{cat.entries.length} entries
                    table
                        thead
                            tr
                                th(style='width:30px;') #
                                th(style='width:auto;') Entrant
                                th.r(style='width:65px;') Score
                                th.r(style='width:65px;') Raw Avg
                                th.c(style='width:70px;') Finalist
                        tbody
                            each r in cat.entries
                                tr(class=(r.meetsMin ? '' : 'below-min'))
                                    td= r.rank
                                    td= r.entrantname
                                    td.r= r.finalscore.toFixed(2)
                                    td.r(class=(r.meetsMin ? '' : 'raw-fail'))= r.rawScore !== null ? r.rawScore.toFixed(2) : '—'
                                    td.c
                                        if r.finalist
                                            span.finalist-badge Finalist
                                        else if !r.meetsMin
                                            span.below-min-label below min

            .form-actions
                form(method='POST' action=baseUrl+'&confirm=1'+ignoreQs)
                    button.btn(type='submit') Write Scores &amp; Set Finalists
                a.btn-secondary(href='/' + slug + '/home?action=program') Cancel

script.
    function cfsNavigate() {
        var checked = document.getElementById('ignoreReadyInput').checked;
        var n       = document.getElementById('topNInput').value || 5;
        var minRaw  = document.getElementById('minRawInput').value || 2.85;
        var base    = (window.JADE_BASE || '') + '/home?action=calcfinalscores';
        location.href = base + (checked ? '&ignoreScoreReady=1' : '') + '&topN=' + n + '&minRawScore=' + minRaw;
    }
    document.addEventListener('change', function(e) {
        var t = e.target;
        if (t.id === 'ignoreReadyInput' || t.id === 'topNInput' || t.id === 'minRawInput') {
            cfsNavigate();
        }
    });
