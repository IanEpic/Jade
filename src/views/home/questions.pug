//- home/questions.pug

form(method='POST' action='/formQuestion')
    input(type='hidden' name='type' value=content.type)
    input(type='hidden' name='task' value='reorder')
    h3(align='center') Question Control

    table(width='640')
        tr(align='left' valign='top')
            th Question No
            th Question Title
            th Description
            th
            th
            th

        each q, i in content.questions
            tr
                td= q.questionid
                td= q.questiontext
                td= q.description
                td: a(href='/formQuestion?questionid=' + q.questionid) Edit
                td: a(href='/formQuestion?questionid=' + q.questionid + '&action=delete' onclick='return confirm("Delete?")') Delete
                td: input(type='text' name='#' + q.questionid value=i+1 size='5' maxlength='5')

        tr
            td(colspan='6')
                a(href='/formQuestion?type=' + content.type) New Question
                | &nbsp;
                button(type='submit') Reorder Questions
