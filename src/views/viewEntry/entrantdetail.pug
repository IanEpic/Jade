//- viewEntry/entrantdetail.pug
- let addr = entrant && entrant.streetaddress
.ve-entrant-grid
    span.lbl Name
    span.val= entrant ? entrant.name : ''
    span.lbl Company
    span.val= entrant ? (entrant.legalentity || '—') : ''
    if addr
        span.lbl Address
        span.val= [addr.address, addr.city, addr.state, addr.code, addr.country].filter(Boolean).join(' ')
    span.lbl Telephone
    span.val= entrant ? (entrant.telephone || '—') : ''
    if entrant && entrant.mobile
        span.lbl Mobile
        span.val= entrant.mobile
    span.lbl Email
    span.val= entrant ? entrant.email : ''
