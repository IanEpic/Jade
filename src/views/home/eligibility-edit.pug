//- home/eligibility-edit.pug

style.
    .el-form { max-width: 800px; margin: 0 auto; }
    .el-form fieldset { border: 1px solid #666; border-radius: 4px; margin-bottom: 16px; padding: 12px 18px; }
    .el-form legend { font-weight: bold; padding: 0 6px; }
    .el-form table { border-collapse: collapse; width: 100%; }
    .el-form td { padding: 4px 8px; vertical-align: top; }
    .el-form td:first-child { white-space: nowrap; text-align: right; padding-right: 12px; width: 1%; }
    .el-form textarea { width: 100%; box-sizing: border-box; }
    .el-form .cat-grid { columns: 3; column-gap: 20px; margin-top: 4px; }
    .el-form .cat-grid label { font-size: 13px; display: flex; align-items: baseline; gap: 5px; break-inside: avoid; padding: 3px 0; }
    .el-form .form-actions { text-align: center; margin-top: 10px; }
    .el-form .form-actions a, .el-form .form-actions button { margin: 0 6px; }

if content.saved
    p(style='color:#4caf50; text-align:center') Saved.

form.el-form(method='POST' action='/formEligibility')
    if content.eligibility
        input(type='hidden' name='eligibilityid' value=content.eligibility.eligibilityid)

    h2(style='text-align:center')= content.isNew ? 'New Eligibility Rule' : 'Edit Eligibility Rule'

    fieldset
        legend Details
        table
            tr
                td(colspan='2' style='text-align:left') Rule text
            tr
                td(colspan='2'): textarea(name='eligibilityrule' rows='6')= content.eligibility ? content.eligibility.eligibilityrule : ''
            tr
                td Applies to all categories
                td
                    select(name='allcats')
                        option(value='0' selected=(!content.eligibility || content.eligibility.allcats != 1)) No
                        option(value='1' selected=(content.eligibility && content.eligibility.allcats == 1)) Yes

    fieldset
        legend Categories
        .cat-grid
            each cat in content.categories
                label
                    input(type='checkbox' name='categories' value=cat.categoryid checked=(content.checkedCategoryIds.indexOf(cat.categoryid) !== -1))
                    = cat.name

    .form-actions
        a(href='/home?action=eligibility') < Eligibility Rules
        button(type='submit') Save Rule
