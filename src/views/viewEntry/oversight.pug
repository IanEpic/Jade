//- viewEntry/oversight.pug
//- Lead-judge / chairperson read-only view of all judges' scores and comments
//- for this entry during the judging phase.

each j in scorePanel.judges
    .ve-subcard
        .ve-subcard-title= j.name
        - var allCriteria = scorePanel.criteria || []
        if allCriteria.length
            table.ve-score-table
                thead
                    tr
                        th Criteria
                        th Score
                tbody
                    each c in allCriteria
                        - var s = (j.scores || []).find(x => x.criteriaid === c.criteriaid)
                        tr
                            td!= c.description
                            td.score-cell= s ? s.score : ''
        each type in ['excel', 'improve', 'other']
            - var cm = (j.comments || []).find(x => x.type === type && x.comment)
            if cm
                .ve-ctype(style='font-size:11px;text-transform:uppercase;letter-spacing:0.05em;color:var(--text-dim);margin-top:8px')= type === 'excel' ? 'Excelled' : (type === 'improve' ? 'Could improve' : 'Other')
                div(style='white-space:pre-wrap;color:var(--text-strong)')= cm.comment
        if !(j.scores && j.scores.length) && !(j.comments && j.comments.some(c => c.comment))
            div(style='color:var(--text-dim);font-style:italic') Not yet judged.
