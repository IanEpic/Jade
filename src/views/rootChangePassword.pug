extends layout

block content
    div(style='max-width:420px; margin:80px auto; font-family:sans-serif;')
        h2(style='text-align:center;') Choose a New Password

        p Please choose a new password before continuing.

        p(style='color:#666; font-size:0.9em;')= passwordRules

        if errors && errors.length
            each e in errors
                p(style='color:#c0392b;')= e

        form(method='POST' action='/login/change-password')
            table
                tr
                    td New password
                    td: input(type='password' name='password' size='30' maxlength='100' autocomplete='new-password' autofocus)
                tr
                    td Confirm password
                    td: input(type='password' name='password2' size='30' maxlength='100' autocomplete='new-password')
                tr: td(colspan='2'): hr
                tr: td(colspan='2' align='center')
                    button.btn(type='submit') Save and Continue
