//- home/userpage-edit.pug

style.
    .up-edit-form { max-width: 860px; margin: 0 auto; }
    .up-edit-form fieldset { border: 1px solid var(--border-mid); border-radius: 4px; margin-bottom: 16px; padding: 12px 18px; }
    .up-edit-form legend { font-weight: bold; padding: 0 6px; color: var(--color-accent-strong); }
    .up-edit-form table { border-collapse: collapse; width: 100%; }
    .up-edit-form td { padding: 5px 8px; vertical-align: middle; }
    .up-edit-form td:first-child { text-align: right; width: 130px; padding-right: 10px; white-space: nowrap; }
    .up-edit-form input[type=text] { background: var(--surface); color: #eee; border: 1px solid var(--border); padding: 5px 8px; border-radius: 3px; font-size: 13px; width: 320px; }
    .up-edit-form textarea { background: var(--surface); color: #eee; border: 1px solid var(--border); padding: 6px 8px; border-radius: 3px; font-size: 13px; width: 100%; box-sizing: border-box; font-family: monospace; }
    .up-edit-form .form-actions { text-align: center; margin-top: 12px; }
    .up-edit-form .form-actions a, .up-edit-form .form-actions button { margin: 0 6px; }
    .alert-err { background: var(--err-bg); color: var(--err-text); padding: 8px 12px; border-left: 4px solid var(--err-border); margin-bottom: 14px; }

if content.saved
    p(style='color:#4caf50; text-align:center') Saved.
if content.error === 'duplicate'
    p.alert-err A page with this name already exists.

form.up-edit-form(method='POST' action='/formPage')
    input(type='hidden' name='pageid' value=content.page.userpageid)

    h2(style='text-align:center') Edit User Page

    fieldset
        legend Details
        table
            tr
                td Page Name
                td: input(type='text' name='name' value=content.page.name maxlength='200')

    fieldset
        legend Visibility
        table
            tr
                td Show to Users
                td: input(type='checkbox' name='show4user' value='1' checked=content.page.show4user)
            tr
                td Show to Judges
                td: input(type='checkbox' name='show4judge' value='1' checked=content.page.show4judge)
            tr
                td Show to Admins
                td: input(type='checkbox' name='show4admin' value='1' checked=content.page.show4admin)

    fieldset
        legend Layout
        table
            tr
                td Show with sidebar
                td
                    input(type='checkbox' name='withsidebar' value='1' checked=content.page.withsidebar)
                    span(style='color:var(--text-dim); font-size:12px; margin-left:8px;') Render inside the program framework (sidebar + navigation). Leave off for a standalone page.

    fieldset
        legend Page Content (HTML)
        textarea#page-html(name='html' rows='20')= content.page.html || ''

    .form-actions
        a.btn-secondary(href='/home?action=userpages') User Pages
        button(type='submit') Save Page

script(defer src='https://cdn.tiny.cloud/1/t5u2zqqe9s1ltcgp3yrcdormdh3wb2qaquf31suupv3rupdw/tinymce/7/tinymce.min.js' referrerpolicy='origin')
script(nonce=nonce).
    //- `defer` is ignored on inline scripts, so wait for DOMContentLoaded (deferred
    //- external scripts — incl. the TinyMCE CDN above — run before it) and guard, so
    //- the editor reliably initialises like the Admin → Program rich-text fields.
    (function () {
        function init() {
            if (typeof tinymce === 'undefined') { return setTimeout(init, 50); }
            if (tinymce.get('page-html')) return;
            var dark = !(document.body && document.body.dataset && document.body.dataset.theme === 'light');
            tinymce.init({
                selector: '#page-html',
                plugins: 'anchor autolink lists link image table code fullscreen',
                toolbar: 'undo redo | blocks | bold italic underline | forecolor backcolor | alignleft aligncenter alignright | bullist numlist | link image table | code fullscreen',
                menubar: false,
                height: 400,
                skin: dark ? 'oxide-dark' : 'oxide',
                content_css: dark ? 'dark' : 'default',
                promotion: false,
            });
        }
        if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', init);
        else init();
    })();
