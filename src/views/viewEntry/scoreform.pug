//- viewEntry/scoreform.pug
//- Equiv of $scoreform in viewEntry.cgi — full judging score form, grouped into
//- inner-cards: Overall Judging Basis / Scores / Comments.

- let jm = scorePanel.judgingModel || {}
- let minVal = parseFloat(jm.minscore) || 0
- let maxVal = parseFloat(jm.maxscore) || 10
- let increment = parseFloat(jm.scoreincrement) || 1
- let scoreOptions = []
- for (let i = minVal; i <= maxVal + 0.0001; i += increment) { scoreOptions.push(Math.round(i * 100) / 100); }
- let scoreMap = {}
each s in (scorePanel.scores || [])
    - scoreMap[s.criteriaid] = s.score

.ve-subcard
    .ve-subcard-title Overall Judging Basis
    div= category.description

form(method='POST' action='/recordScores')
    input(type='hidden' name='entryid' value=entry.entryid)
    input(type='hidden' name='userid'  value=user.userid)

    .ve-subcard
        .ve-subcard-title Scores
        if jm.judgeinstructions
            div(style='margin-bottom:10px')!= jm.judgeinstructions
        table.ve-score-table
            thead
                tr
                    th Criteria
                    th
                        | Score
                        span.ve-req *
            tbody
                each c in (scorePanel.criteria || [])
                    if !c.weight
                        tr.crit-section: td(colspan='2')!= c.description
                    else
                        tr
                            td!= c.description
                            td.score-cell
                                select(name='score~' + c.criteriaid)
                                    option(value='') Select
                                    if jm.nullscoreallowed
                                        option(value=jm.nullscorevalue selected=(scoreMap[c.criteriaid] === jm.nullscorevalue))= jm.nullscorelabel
                                    each val in scoreOptions
                                        option(value=val selected=(scoreMap[c.criteriaid] == val))= val

    if jm.commentsallowed
        .ve-subcard
            .ve-subcard-title Comments
            p Entrants consistently tell us that constructive feedback from judges is vitally important to them. Please bear this in mind as you provide your responses below. Your responses will be passed directly to the entrant without editing. Your identity will not be revealed to the entrant (but may be revealed to other judges).
            .ve-comment-field
                label
                    | Please provide a message to the entrant highlighting areas in which this entrant has excelled:
                    span.ve-req *
                textarea(name='comment~excel' rows='5')= scorePanel.excel
            .ve-comment-field
                label
                    | The entrant will benefit from your advice on areas in which they could improve next year:
                    span.ve-req *
                textarea(name='comment~improve' rows='5')= scorePanel.improve
            .ve-comment-field
                label Do you have any other constructive comments that may assist this entrant?
                textarea(name='comment~other' rows='5')= scorePanel.other

    - let feedbackStyle = 'background:#c0392b;color:#fff;padding:12px;margin-bottom:8px;border-radius:4px;' + (scorePanel.commentFeedback ? '' : 'display:none;')
    div#comment-feedback(style=feedbackStyle)
        b Your comments could not be saved — please review the feedback below and make changes before resubmitting:
        br
        br
        span#comment-feedback-text= scorePanel.commentFeedback || ''

    .ve-req-note
        span.ve-req *
        |  All scores and the "excel" and "improve" comments are required to complete judging this entry. You can save your progress and return later to finish.

    .ve-judge-submit
        button#score-submit.btn(type='submit')= jm.submitbuttonlabel || 'Save Scores'

script(src='/js/score-form.js?v=' + buildHash)
