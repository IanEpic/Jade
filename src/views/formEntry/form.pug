//- formEntry/form.pug
//- Equiv of $form_blank / $form_edit in formEntry.cgi.

style.
    .req { color: #c48f06; margin-left: 2px; }
    .req-note { font-size: 12px; color: #888; margin-bottom: 10px; }

- let isEdit = mode === 'edit'

if errors && errors.length
    div(style='background:#5a0000; color:#fff; border-left:4px solid #c44; padding:10px 14px; margin-bottom:14px;')
        each err in errors
            p(style='margin:2px 0')= err

if isEdit
    p Edit Entry Number: #{entry.entryid}
    br
    br
else
    p(style='text-align:center; color:#c48f06; font-size:18px; margin-bottom:2px') Start a New Entry
    p(style='text-align:center; color:#aaa; font-size:13px; margin-top:0; margin-bottom:16px') Step 3 — Set up your entry below and then proceed to the questions

p.req-note
    span.req *
    |  Required field

form(name='entryform' method='POST' action='/formEntry')
    if isEdit
        input(type='hidden' name='entryid' value=entry.entryid)
    input(type='hidden' name='categoryid' value=category.categoryid)

    table(width='780' style='text-align:left;')
        tr
            td: b Category
            td= category.name
        tr(valign='top')
            td: b Description
            td= category.description
        tr
            td(colspan='2' align='left'): hr

        //- ── Eligibility ─────────────────────────────────────────────────
        if eligibilityLinks && eligibilityLinks.length
            tr
                td(colspan='2')
                    b Eligibility
                    br
                    br
                    | Entries in this Category must adhere to the following rules:
            tr
                td(colspan='2')
                    ul
                        each el in eligibilityLinks
                            li!= el.eligibilityrule
            tr: td(colspan='2'): hr

        //- ── Criteria ─────────────────────────────────────────────────────
        if criteria && criteria.length
            tr
                td(colspan='2')
                    b Criteria
                    br
                    br
                    | Entries in this category will be assessed according to the following criteria:
            tr
                td(colspan='2')
                    table
                        tr
                            td: b Criterion
                            td: b Weight
                        each c in criteria
                            tr
                                td!= c.description
                                td(align='center')= c.weight + '%'
            tr: td(colspan='2'): hr

        //- ── Your Reference ───────────────────────────────────────────────
        tr
            td(colspan='2' align='left'): b Your Reference
        tr
            td(colspan='2' align='left') Enter a word or number to distinguish this entry from any others you might have
        tr
            td
            td: input(type='text' name='userref' value=(isEdit ? entry.userref || '' : '') size='50' maxlength='50')
        tr: td(colspan='2' align='left'): hr

        //- ── Entrant selection ────────────────────────────────────────────
        if entrants && entrants.length
            tr
                td
                    b Select an Entrant
                    span.req *
                td
                    select(name='entrantid')
                        if !isEdit
                            option(value='a') ------Please Select------
                        option(value='b') New Entrant Below
                        each ent in entrants
                            option(value=ent.entrantid selected=(isEdit && entry.entrantid === ent.entrantid))= ent.name

        tr(valign='top')
            td
                if !entrants || !entrants.length
                    | Create a new Entrant
                else
                    | or create a new Entrant
            td
                //- Inline new entrant fields (shown/hidden by JS)
                - var hasEntrants = entrants && entrants.length
                - var hasAddresses = addresses && addresses.length
                table#new-entrant-fields(style=hasEntrants ? 'display:none' : '')
                    tr
                        td
                            | Entrant Name
                            span.req *
                        td: input(type='text' name='name' size='50' maxlength='300')
                    tr
                        td Entrant Type
                        td
                            select(name='type')
                                each opt in ['Individual', 'Business', 'Company']
                                    option= opt
                    tr
                        td Company Name (if applicable)
                        td: input(type='text' name='legalentity' size='50' maxlength='300')

                    //- Street address
                    if hasAddresses
                        tr
                            td
                                | Select a Street Address
                                span.req *
                            td
                                select(name='streetaddressid')
                                    option(value='a') ------Please Select------
                                    option(value='b') New Address Below
                                    each addr in addresses
                                        option(value=addr.addressid)= addr.address + ', ' + addr.city + ', ' + addr.state
                    tr(valign='top')
                        td
                            if !hasAddresses
                                | Enter a Street Address
                        td
                            table#street-address-fields(style=hasAddresses ? 'display:none' : '')
                                tr
                                    td
                                        | Address
                                        span.req *
                                    td: input(type='text' name='streetaddress' size='50' maxlength='100')
                                tr
                                    td
                                        | City
                                        span.req *
                                    td: input(type='text' name='streetcity' size='50' maxlength='50')
                                tr
                                    td
                                        | State
                                        span.req *
                                    td: input(type='text' name='streetstate' size='20' maxlength='20')
                                tr
                                    td
                                        | Postcode
                                        span.req *
                                    td: input(type='text' name='streetcode' size='10' maxlength='10')
                                tr
                                    td
                                        | Country
                                        span.req *
                                    td: input(type='text' name='streetcountry' value='Australia' size='50' maxlength='50')

                    //- Postal address
                    if hasAddresses
                        tr
                            td
                                | Select a Postal Address
                                span.req *
                            td
                                select(name='postaladdressid')
                                    option(value='a') ------Please Select------
                                    option(value='b') New Address Below
                                    option(value='c') Same as above
                                    each addr in addresses
                                        option(value=addr.addressid)= addr.address + ', ' + addr.city + ', ' + addr.state
                    tr(valign='top')
                        td
                            if !hasAddresses
                                | Enter a Postal Address
                        td
                            table#postal-address-fields(style=hasAddresses ? 'display:none' : '')
                                tr
                                    td
                                        | Address
                                        span.req *
                                    td: input(type='text' name='postaladdress' size='50' maxlength='100')
                                tr
                                    td
                                        | City
                                        span.req *
                                    td: input(type='text' name='postalcity' size='50' maxlength='50')
                                tr
                                    td
                                        | State
                                        span.req *
                                    td: input(type='text' name='postalstate' size='20' maxlength='20')
                                tr
                                    td
                                        | Postcode
                                        span.req *
                                    td: input(type='text' name='postalcode' size='10' maxlength='10')
                                tr
                                    td
                                        | Country
                                        span.req *
                                    td: input(type='text' name='postalcountry' value='Australia' size='50' maxlength='50')

                    tr
                        td
                            | Telephone no
                            span.req *
                        td: input(type='text' name='telephone' value=user.telephone || '' size='50' maxlength='50')
                    tr
                        td
                            | Mobile
                            span.req *
                        td: input(type='text' name='mobile' value=user.mobile || '' size='50' maxlength='50')
                    tr
                        td
                            | Email
                            span.req *
                        td: input(type='text' name='email' value=user.email || '' size='50' maxlength='100')

        tr: td(colspan='2'): hr
        tr
            td(colspan='2' align='center')
                a.btn-secondary(href='/home') Cancel
                button.btn(type='submit' name='submit' value='Save') Save &amp; Return Home
                button.btn(type='submit' name='submit' value='SaveProceed') Save &amp; Proceed to Questions

script(src='/js/jade.js?v=' + buildHash)
script(src='/js/form-entry.js?v=' + buildHash)
